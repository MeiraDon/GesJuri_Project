@page "/Account/Login"
@layout EmptyLayout
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using GesCPSI_Project.Models

@inject SignInManager<UserModel> SignInManager
@inject UserManager<UserModel> UserManager
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

@attribute [AllowAnonymous]

<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:#FAFAF7;">
    <div style="text-align:center;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <p style="margin-top:16px;color:#5E6B7D;">Connexion en cours...</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Password { get; set; }
    [SupplyParameterFromQuery] public bool RememberMe { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Cette page est servie côté serveur (statique) avant que Blazor ne prenne le relais
        // → on peut écrire les cookies sans problème
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is null)
        {
            Navigation.NavigateTo("/login?error=httpContext", forceLoad: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            Navigation.NavigateTo("/login?error=missing", forceLoad: true);
            return;
        }

        var user = await UserManager.FindByEmailAsync(Email);
        if (user is null || !user.IsActive)
        {
            Navigation.NavigateTo("/login?error=invalid", forceLoad: true);
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            user.UserName!, Password, RememberMe, lockoutOnFailure: true);

        if (result.IsLockedOut)
        {
            Navigation.NavigateTo("/login?error=lockout", forceLoad: true);
            return;
        }

        if (!result.Succeeded)
        {
            Navigation.NavigateTo("/login?error=invalid", forceLoad: true);
            return;
        }

        // ✅ Connexion réussie
        user.DerniereConnexion = DateTime.UtcNow;
        await UserManager.UpdateAsync(user);

        // Redirection
        // Redirection
        if (user.MustChangePassword)
        {
            Navigation.NavigateTo("/change-password", forceLoad: true);
        }
        else
        {
            // Calcul sécurisé de l'URL cible
            string target = "/";

            if (!string.IsNullOrWhiteSpace(ReturnUrl))
            {
                // Si ReturnUrl commence déjà par "/", on l'utilise tel quel
                // Sinon on ajoute "/" devant
                if (ReturnUrl.StartsWith("/"))
                {
                    target = ReturnUrl;
                }
                else if (ReturnUrl.StartsWith("http"))
                {
                    // URL absolue : on extrait juste le chemin
                    try
                    {
                        var uri = new Uri(ReturnUrl);
                        target = uri.PathAndQuery;
                    }
                    catch
                    {
                        target = "/";
                    }
                }
                else
                {
                    target = "/" + ReturnUrl;
                }
            }

            Navigation.NavigateTo(target, forceLoad: true);
        }
    }
}