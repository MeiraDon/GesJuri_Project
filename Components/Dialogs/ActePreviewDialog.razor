@using MudBlazor
@using GesCPSI_Project.Models
@using GesCPSI_Project.Reports
@using GesCPSI_Project.Interfaces
@using GesCPSI_Project.Components.Dialogs.ActePreviewTemplates

@inject ActReportDataBuilder ReportBuilder
@inject ITypesAct TypesActService
@inject IAjoutAct AjoutActService
@inject ISnackbar Snackbar

<MudDialog Class="acte-preview-dialog">
    
    <DialogContent>
        @if (_loading)
        {
            <div class="text-center py-5">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <div class="mt-3 text-muted">Chargement de l'aperçu...</div>
            </div>
        }
        else if (_data is null)
        {
            <MudAlert Severity="Severity.Error">
                Impossible de charger l'aperçu de cet acte.
            </MudAlert>
        }
        else
        {
            @* 🎯 DISPATCHER : choisit le bon template *@
            <div id="acte-print-area">
                @switch (_templateType)
                {
                    case TemplateType.CautionnementSpecifiquePhysique:
                        <_Template1_SpecifiquePhysique Data="_data" />
                        break;

                    case TemplateType.CautionnementSpecifiqueMorale:
                        <_Template2_SpecifiqueMorale Data="_data" />
                        break;

                    case TemplateType.ToutEngagementPhysique:
                        <_Template3_TousEngagPhysique Data="_data" />
                        break;

                    case TemplateType.ToutEngagementMorale:
                        <_Template4_TousEngagMorale Data="_data" />
                        break;

                    case TemplateType.DelegationLoyersMorale:
                        <_Template5_DelegationLoyers Data="_data" />
                        break;

                    default:
                        <MudAlert Severity="Severity.Warning">
                            Modèle d'acte non reconnu (@_templateType).
                        </MudAlert>
                        break;
                }
            </div>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Fermer</MudButton>
    </DialogActions>

</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int ActeId { get; set; }

    private ActCautionnementReportModel? _data;
    private TemplateType _templateType = TemplateType.CautionnementSpecifiquePhysique;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Données complètes via le builder
            _data = await ReportBuilder.BuildAsync(ActeId);

            // 2. Récupère le TemplateType depuis AjoutActModel lié
            var acte = await TypesActService.GetByIdAsync(ActeId);
            if (acte?.IdAjout > 0)
            {
                var ajout = await AjoutActService.GetByIdAsync(acte.IdAjout);
                if (ajout is not null)
                {
                    _templateType = ajout.TemplateType;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur de chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Close() => MudDialog.Close();


    private static string GetTemplateLabel(TemplateType type) => type switch
    {
        TemplateType.CautionnementSpecifiquePhysique => "Cautionn. Spéc. PP",
        TemplateType.CautionnementSpecifiqueMorale => "Cautionn. Spéc. PM",
        TemplateType.ToutEngagementPhysique => "Tout Engag. PP",
        TemplateType.ToutEngagementMorale => "Tout Engag. PM",
        TemplateType.DelegationLoyersMorale => "Délég. Loyers PM",
        _ => "—"
    };
}

