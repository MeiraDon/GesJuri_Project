@using GesCPSI_Project.Reports
@using static GesCPSI_Project.Components.Dialogs.ActePreviewTemplates.ActePreviewHelpers

<div class="acte-document">

    @* ============= EN-TÊTE BANQUE ============= *@
    <header class="acte-header">
        <div class="acte-bank-block">
            <div class="acte-bank-name">@Data.BanqueReportNomRaisonSocialBnq</div>
            @if (!string.IsNullOrWhiteSpace(Data.BanqueReportSigleBnq))
            {
                <div class="acte-bank-sigle">@Data.BanqueReportSigleBnq</div>
            }
            <div class="acte-bank-meta">
                @Data.BanqueReportFormeJuridique
                @if (!string.IsNullOrWhiteSpace(Data.BanqueReportCapitalSocial))
                {
                    <span> au capital de @Data.BanqueReportCapitalSocial FCFA</span>
                }
            </div>
            <div class="acte-bank-meta">
                Siège social : @Data.BanqueReportSiegeSocial
            </div>
            <div class="acte-bank-meta">
                RCCM : @Data.BanqueReportRegistreCommerce — SWIFT : @Data.BanqueReportSwift
            </div>
        </div>
    </header>

    @* ============= TITRE PRINCIPAL ============= *@
    <h1 class="acte-title">
        ACTE DE CAUTIONNEMENT SOLIDAIRE ET INDIVISIBLE<br />
        TOUT ENGAG PARTICULIER POUR ENT INDIV ou SOCIETE-VF
    </h1>
    <div class="acte-subtitle">
        – PERSONNE PHYSIQUE –
    </div>
    <div class="acte-ref">
        N° @Data.CautionnementReportNumeroCautionmt
    </div>

    @* ============= ENTRE LES SOUSSIGNÉS ============= *@
    <h2 class="acte-section-title">ENTRE LES SOUSSIGNÉS :</h2>

    <p class="acte-para">
        <strong>M @Data.CautionReportNomComplet</strong>,
        né(e) le @FormatDate(Data.CautionReportDateNaiss)
        à @Data.CautionReportLieuNaiss (@Data.CautionReportPaysNaiss),
        de nationalité @Data.CautionReportNationalite,
        @Data.CautionReportProfessionClt,
        demeurant à @Data.CautionReportAdressecomplet
        (@Data.CautionReportVilleCommune, @Data.CautionReportPaysResidn),
        BP @Data.CautionReportBPClt,
        Tél. Bur : @Data.CautionReportTelBur,
        Cell. : @Data.CautionReportTelCel,
        Dom. : @Data.CautionReportTelDom,
        @FormatSituation(Data.CautionReportSituationMatrim, Data.CautionReportNomConjoint),
        titulaire de la pièce d'identité @Data.CautionReportTypePieceID
        n° @Data.CautionReportNumPieceID
        délivrée le @FormatDate(Data.CautionReportDateDelivPiece)
        à @Data.CautionReportLieuDelivPiece
        par @Data.CautionReportPersonDelivPiece,
        ci-après dénommé(e) « <strong>la Caution</strong> »,
    </p>

    <p class="acte-para acte-para-spaced">D'UNE PART,</p>
    <p class="acte-para">ET</p>

    <p class="acte-para">
        <strong>@Data.BanqueReportNomRaisonSocialBnq</strong>
        (@Data.BanqueReportSigleBnq),
        @Data.BanqueReportFormeJuridique au capital de @Data.BanqueReportCapitalSocial FCFA,
        dont le siège social est sis à @Data.BanqueReportSiegeSocial,
        immatriculée au RCCM sous le numéro @Data.BanqueReportRegistreCommerce,
        code SWIFT @Data.BanqueReportSwift,
        représentée par <strong>@Data.BanqueReportRepresentantBnq</strong>,
        en sa qualité de @Data.BanqueReportFonctionRepresentant,
        ci-après dénommée « <strong>la Banque</strong> » ou « <strong>BOA-TOGO</strong> »,
    </p>

    <p class="acte-para acte-para-spaced">D'AUTRE PART,</p>

    <p class="acte-para acte-para-italic">
        La Caution et la BOA-TOGO étant ci-après dénommées, (i) ensemble, les « Parties », ou,
        (ii) séparément, chaque « Partie », ou, individuellement, comme susmentionné.
    </p>

    @* ============= PRÉAMBULE — SPÉCIFIQUE TOUT ENGAGEMENT ============= *@
    <h2 class="acte-section-title">Préambule</h2>

    <p class="acte-para">
        1. <strong>M @Data.DebiteurReportNomComplet</strong>,
        né(e) le @FormatDate(Data.DebiteurReportDateNaiss)
        à @Data.DebiteurReportLieuNaiss (@Data.DebiteurReportPaysNaiss),
        de nationalité @Data.DebiteurReportNationalite,
        @Data.DebiteurReportProfessionClt,
        demeurant à @Data.DebiteurReportAdressecomplet,
        titulaire de la pièce d'identité @Data.DebiteurReportTypePieceID
        n° @Data.DebiteurReportNumPieceID,
        ci-après dénommé(e) « <strong>le Débiteur Cautionné</strong> »,
        est titulaire dans les livres de la Banque du compte courant
        n° <strong>@Data.DebiteurReportNumCompte</strong>
        (le « <strong>Compte Courant</strong> »).
    </p>

    <p class="acte-para">
        2. Aux termes de la convention de compte courant, la Banque a consenti et pourra consentir
        au Débiteur Cautionné, dans le cadre du fonctionnement de ce Compte Courant,
        divers concours et facilités sous forme notamment de découverts, avances, escomptes,
        crédits par caisse ou par signature
        (l'ensemble étant ci-après dénommé « <strong>les Concours</strong> »).
        @if (!string.IsNullOrWhiteSpace(Data.PretReportReferenceConvention))
        {
            <span>Référence : <strong>@Data.PretReportReferenceConvention</strong>.</span>
        }
    </p>

    <p class="acte-para">
        3. En garantie du remboursement de tous les Concours présents et futurs et,
        plus généralement, du solde débiteur du Compte Courant à hauteur du Montant Cautionné,
        la Caution s'engage à se porter caution solidaire et indivisible du Débiteur Cautionné,
        à concurrence d'un montant maximum de
        <strong>@FormatMontant(Data.CautionnementReportMontantCautionne) FCFA</strong>
        (@Data.CautionnementReportMontantLettreCautionmt),
        en principal, les intérêts, commissions, frais, taxes et autres accessoires
        (le « <strong>Montant Cautionné</strong> »).
    </p>

    @* ============= CECI EXPOSÉ ============= *@
    <h2 class="acte-section-title">CECI EXPOSÉ, IL EST ARRÊTÉ ET CONVENU CE QUI SUIT :</h2>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 1 :</strong> L'exposé préalable ci-dessus et les Annexes ci-jointes
            ont la même valeur juridique que le présent cautionnement solidaire tous engagements
            (le « <strong>Cautionnement</strong> ») dont ils font partie intégrante.
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 2 :</strong> La Caution déclare avoir parfaite connaissance des conditions
            de fonctionnement du Compte Courant et de la nature des Concours susceptibles d'être
            consentis par la Banque au Débiteur Cautionné. Elle se déclare caution solidaire et indivisible
            de toutes les sommes qui seront ou pourraient être dues à la Banque par le Débiteur Cautionné
            au titre du solde débiteur du Compte Courant et de tous les Concours.
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 3 :</strong> Les engagements de la Caution sont expressément limités
            au Montant Cautionné, à savoir la somme maximale en principal, intérêts, commissions,
            frais, taxes et autres accessoires, y compris les frais de recouvrement de créance,
            de <strong>@FormatMontant(Data.CautionnementReportMontantCautionne) FCFA</strong>
            (@Data.CautionnementReportMontantLettreCautionmt).
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 4 :</strong> Le présent contrat de cautionnement prend effet à compter du
            <strong>@FormatDate(Data.CautionnementReportDateEffetCautionmt)</strong>
            et reste valable jusqu'au remboursement intégral de l'ensemble des sommes dues
            au titre du solde débiteur du Compte Courant, soit au plus tard le
            <strong>@FormatDate(Data.CautionnementReportDateExpirationCautionmt)</strong>.
            Il peut être révoqué à tout moment par la Caution avant que la somme maximale garantie
            ait été atteinte. Tous les engagements du Débiteur Cautionné nés avant la révocation
            resteront cependant garantis par la Caution.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.CautionnementReportConditionsRevocationCautionmt))
        {
            <p class="acte-para"><em>@Data.CautionnementReportConditionsRevocationCautionmt</em></p>
        }
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 5 :</strong> La Banque est tenue, dans le mois suivant chaque semestre civil,
            de communiquer à la Caution un état détaillé du solde du Compte Courant, précisant les Concours
            consentis, leurs montants, échéances, intérêts et accessoires, conformément à l'article 25
            de l'Acte Uniforme OHADA portant organisation des Sûretés.
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 6 :</strong> La Banque informera la Caution de toute défaillance
            du Débiteur Cautionné dans le mois suivant la constatation, ainsi que de toute prorogation
            ou déchéance du terme des Concours.
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 7 :</strong> En cas de défaillance du Débiteur Cautionné, la Caution
            sera tenue de payer à la Banque ce qui lui est dû au titre du solde débiteur du Compte Courant,
            dans la limite du Montant Cautionné, dans un délai maximum de trente (30) jours à compter
            de la première demande écrite de la Banque par lettre recommandée avec accusé de réception
            ou par acte extrajudiciaire.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.CautionnementReportObligationsCaution))
        {
            <p class="acte-para"><em>@Data.CautionnementReportObligationsCaution</em></p>
        }
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 8 :</strong> Conformément aux articles 27 et 28 de l'Acte Uniforme OHADA
            portant organisation des Sûretés, la Caution Solidaire ne dispose pas du bénéfice
            de discussion et de division. La Banque pourra réclamer à la Caution le paiement
            sans avoir à poursuivre préalablement le Débiteur Cautionné.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.CautionnementReportClauseSubrogation))
        {
            <p class="acte-para">@Data.CautionnementReportClauseSubrogation</p>
        }
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 9 :</strong> La preuve du solde débiteur du Compte Courant et de l'existence
            des créances résultera suffisamment des relevés de compte établis par la Banque,
            qui font foi entre les Parties sauf preuve contraire.
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 10 :</strong> Le Cautionnement ne fait pas novation et s'ajoute à toutes
            les autres garanties réelles ou personnelles qui ont pu ou pourront être consenties
            en faveur de la Banque par le Débiteur Cautionné ou par des tiers.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.CautionnementReportClauseNonNovation))
        {
            <p class="acte-para">@Data.CautionnementReportClauseNonNovation</p>
        }
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 11 :</strong> Les obligations de la Caution sont stipulées indivisibles ;
            leur exécution pourra être exigée en entier, à concurrence du Montant Cautionné,
            de n'importe lequel des héritiers, successeurs ou ayants droit de la Caution.
        </p>
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 12 :</strong> Tous droits, frais de timbres, impôts et autres frais
            relatifs au Cautionnement sont à la charge du Débiteur Cautionné et de la Caution.
            Le Débiteur Cautionné autorise la Banque à débiter son Compte Courant
            n° <strong>@Data.DebiteurReportNumCompte</strong> du montant des frais y afférents.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.ChargeReportTypeCharge))
        {
            <p class="acte-para">
                <em>
                    Charge : @Data.ChargeReportTypeCharge —
                    Montant : @FormatMontant(Data.ChargeReportMontantCharge) FCFA —
                    Payé par : @Data.ChargeReportPayePar.
                </em>
            </p>
        }
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 13 :</strong> Pour l'exécution du Cautionnement, la Caution et la Banque
            font élection de domicile, chacune pour ce qui la concerne, aux adresses mentionnées
            en tête des présentes.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.CautionnementReportElectionDomicile))
        {
            <p class="acte-para">@Data.CautionnementReportElectionDomicile</p>
        }
    </article>

    <article class="acte-article">
        <p class="acte-para">
            <strong>Article 14 :</strong> Tout différend résultant de la validité, l'interprétation
            ou de l'exécution du présent acte fera d'abord l'objet d'un règlement à l'amiable.
            À défaut, dans un délai de trente (30) jours, le différend sera soumis au Tribunal de Lomé.
        </p>
        @if (!string.IsNullOrWhiteSpace(Data.CautionnementReportReglementDifferend))
        {
            <p class="acte-para">@Data.CautionnementReportReglementDifferend</p>
        }
    </article>

    @* ============= FAIT À LOMÉ ============= *@
    <p class="acte-closing">
        Fait à <strong>@Data.CautionnementReportLieuSignatureCautionmt</strong>,
        le <strong>@FormatDateLong(Data.CautionnementReportDateSignatureCautionmt)</strong>
    </p>
    <p class="acte-closing-mention">
        En trois exemplaires originaux, dont un pour l'enregistrement.
    </p>

    @* ============= MENTIONS MANUSCRITES SPÉCIFIQUES TOUT ENGAGEMENT ============= *@
    <div class="acte-mention-box">
        <p>
            <strong>(1)</strong> Faire précéder la signature de la Caution de la mention manuscrite :
            « <strong>
                Bon pour caution solidaire et indivisible tous engagements du solde débiteur
                du compte courant
            </strong>, à concurrence du Montant Cautionné, soit la somme maximale de
            <strong>@FormatMontant(Data.CautionnementReportMontantCautionne) FCFA</strong>
            (@Data.CautionnementReportMontantLettreCautionmt) en principal, intérêts, commissions,
            frais, taxes, autres accessoires et frais de recouvrement de créance ».
        </p>
        <p>
            <strong>(2)</strong> Faire précéder la signature de la Banque de la mention « Bon pour accord ».
        </p>
    </div>

    @* ============= SIGNATURES ============= *@
    <div class="acte-signatures">
        <div class="acte-signature-block">
            <div class="acte-signature-label">LA CAUTION (1)</div>
            <div class="acte-signature-name">@Data.CautionReportNomComplet</div>
            <div class="acte-signature-line"></div>
        </div>

        <div class="acte-signature-block">
            <div class="acte-signature-label">LA BANQUE (2)</div>
            <div class="acte-signature-name">@Data.BanqueReportRepresentantBnq</div>
            <div class="acte-signature-role">@Data.BanqueReportFonctionRepresentant</div>
            <div class="acte-signature-line"></div>
        </div>
    </div>

    <div class="acte-collaborator">
        Signatures recueillies en présence du collaborateur BOA-TOGO,
        M. <strong>@Data.BanqueReportNomCollaborateur</strong><br />
        Visa du collaborateur BOA-TOGO : @Data.BanqueReportVisaCollaborateur
    </div>

    @* ============= TÉMOINS ============= *@
    @if (!string.IsNullOrWhiteSpace(Data.Temoin1ReportNomComplet) || !string.IsNullOrWhiteSpace(Data.Temoin2ReportNomComplet))
    {
        <div class="acte-witnesses-mention">
            Faire précéder la signature des témoins de la mention :
            « Je certifie de l'identité et de la présence de M @Data.CautionReportNomComplet
            et atteste que la nature et les effets du présent acte lui ont été précisés ».
        </div>

        <div class="acte-signatures acte-witnesses">
            @if (!string.IsNullOrWhiteSpace(Data.Temoin1ReportNomComplet))
            {
                <div class="acte-signature-block">
                    <div class="acte-signature-label">TÉMOIN 1</div>
                    <div class="acte-signature-name">@Data.Temoin1ReportNomComplet</div>
                    <div class="acte-signature-line"></div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Data.Temoin2ReportNomComplet))
            {
                <div class="acte-signature-block">
                    <div class="acte-signature-label">TÉMOIN 2</div>
                    <div class="acte-signature-name">@Data.Temoin2ReportNomComplet</div>
                    <div class="acte-signature-line"></div>
                </div>
            }
        </div>
    }

    @* ============= ANNEXE 1 - AUTORISATION DÉBIT ============= *@
    <div class="acte-page-break"></div>
    <h2 class="acte-annexe-title">ANNEXE 1 — AUTORISATION DE DÉBIT AUTOMATIQUE</h2>

    <p class="acte-para">
        <strong>NOM :</strong> @Data.DebiteurReportNom<br />
        <strong>PRÉNOMS :</strong> @Data.DebiteurReportPrenoms<br />
        <strong>ADRESSE :</strong> @Data.DebiteurReportAdressecomplet
    </p>

    <p class="acte-para">
        Je soussigné(e) <strong>@Data.CautionReportNomComplet</strong>, Caution solidaire,
        à la garantie de tous les engagements présents et futurs du Compte Courant
        n° <strong>@Data.DebiteurReportNumCompte</strong> ouvert au nom de
        <strong>@Data.DebiteurReportNomComplet</strong> dans les livres de la BANK OF AFRICA - TOGO,
        à hauteur de <strong>@FormatMontant(Data.CautionnementReportMontantCautionne) FCFA</strong>
        (@Data.CautionnementReportMontantLettreCautionmt),
        j'ai contracté à l'égard de la Banque un engagement de caution solidaire et indivisible
        suivant acte du <strong>@FormatDate(Data.CautionnementReportDateSignatureCautionmt)</strong>.
    </p>

    <p class="acte-para">
        En vertu de cet engagement, j'autorise dès à présent et irrévocablement la Banque à débiter
        mon compte n° <strong>@Data.CautionReportNumCompte</strong> de toutes sommes
        qui pourraient être dues à la Banque par le Débiteur Cautionné au titre du solde débiteur
        du Compte Courant, dans la limite du Montant Cautionné.
    </p>

    @* ============= ANNEXE 2 - TÉMOINS ============= *@
    @if (!string.IsNullOrWhiteSpace(Data.Temoin1ReportNomComplet))
    {
        <div class="acte-page-break"></div>
        <h2 class="acte-annexe-title">ANNEXE 2 — IDENTIFICATION DES TIERS</h2>

        <h3 class="acte-sub-title">Témoin 1</h3>
        <p class="acte-para">
            <strong>M @Data.Temoin1ReportNomComplet</strong>,
            né(e) le @FormatDate(Data.Temoin1ReportDateNaiss)
            à @Data.Temoin1ReportLieuNaiss (@Data.Temoin1ReportPaysNaiss),
            de nationalité @Data.Temoin1ReportNationalite,
            @Data.Temoin1ReportProfessionClt,
            demeurant à @Data.Temoin1ReportAdressecomplet,
            titulaire de la pièce @Data.Temoin1ReportTypePieceID
            n° @Data.Temoin1ReportNumPieceID.
        </p>

        @if (!string.IsNullOrWhiteSpace(Data.Temoin2ReportNomComplet))
        {
            <h3 class="acte-sub-title">Témoin 2</h3>
            <p class="acte-para">
                <strong>M @Data.Temoin2ReportNomComplet</strong>,
                né(e) le @FormatDate(Data.Temoin2ReportDateNaiss)
                à @Data.Temoin2ReportLieuNaiss (@Data.Temoin2ReportPaysNaiss),
                de nationalité @Data.Temoin2ReportNationalite,
                @Data.Temoin2ReportProfessionClt,
                demeurant à @Data.Temoin2ReportAdressecomplet,
                titulaire de la pièce @Data.Temoin2ReportTypePieceID
                n° @Data.Temoin2ReportNumPieceID.
            </p>
        }
    }

    @* ============= LETTRE HUISSIER ============= *@
    @if (!string.IsNullOrWhiteSpace(Data.EntiteJuridiqueReportNomHuissier))
    {
        <div class="acte-page-break"></div>
        <div class="acte-letter">
            <div class="acte-letter-header">
                <div>Lomé, le @FormatDateLong(Data.EntiteJuridiqueReportDateActeJuridique)</div>
                <div>Direction Juridique</div>
                <div>N/Réf. : @Data.EntiteJuridiqueReportReference</div>
            </div>

            <div class="acte-letter-recipient">
                <strong>Maître @Data.EntiteJuridiqueReportNomHuissier</strong><br />
                Huissier de Justice<br />
                @Data.EntiteJuridiqueReportVilleHuissier
            </div>

            <p class="acte-para">
                <strong>Objet :</strong> Cautionnement solidaire tous engagements
                du solde débiteur du compte courant<br />
                <strong>Dossier :</strong> @Data.EntiteJuridiqueReportNumeroDossier —
                @Data.EntiteJuridiqueReportNomDossier
            </p>

            <p class="acte-para">Cher Maître,</p>

            <p class="acte-para">Nous vous remettons ci-joint :</p>

            <ul class="acte-list">
                <li>
                    Copie de la convention de compte courant ouvert au nom de
                    @Data.DebiteurReportNomComplet (compte n° @Data.DebiteurReportNumCompte) ;
                </li>
                <li>
                    Un exemplaire de l'acte de cautionnement solidaire tous engagements
                    à notre profit à hauteur de @FormatMontant(Data.CautionnementReportMontantCautionne) FCFA
                    (« <strong>Montant cautionné</strong> »).
                </li>
            </ul>

            <p class="acte-para">
                Nous vous prions de bien vouloir procéder à l'enregistrement de l'acte de cautionnement
                auprès de l'Office Togolais des Recettes.
            </p>

            <p class="acte-para">
                Votre intervention accomplie, vous voudrez bien nous retourner les documents originaux
                dûment enregistrés.
            </p>

            <p class="acte-letter-signature">
                Pour la BOA-TOGO,<br /><br />
                <strong>@Data.EntiteJuridiqueReportResponsable</strong><br />
                <em>@Data.EntiteJuridiqueReportFonctionResponsable</em>
            </p>
        </div>
    }

    @* ============= FOOTER ============= *@
    <footer class="acte-footer">
        <div>Document généré le @DateTime.Now.ToString("dd/MM/yyyy à HH:mm")</div>
        <div class="acte-watermark">APERÇU — Document non officiel</div>
    </footer>

</div>

@code {
    [Parameter, EditorRequired]
    public ActCautionnementReportModel Data { get; set; } = default!;
}