@code {
    [Parameter, EditorRequired]
    public ClientModelViewModel Debiteur { get; set; } = null!;

    [Parameter]
    public EventCallback OnNext { get; set; }

    private async Task OnSubmit()
    {
        await OnNext.InvokeAsync();
    }

    private Task OnTypeClientAfter()
    {
        var value = Debiteur.TypeClient;

        if (value == "Personne Morale")
        {
            Debiteur.Nom = "";
            Debiteur.Prenoms = "";
            Debiteur.Sexe = "";
        }
        else
        {
            Debiteur.NomRaisonsociale = "";
            Debiteur.NomRepresentant = "";
        }

        return Task.CompletedTask;
    }


    private Task OnSituationAfter()
    {
        if (Debiteur.SituationMatrim != "Marié(e)")
        {
            Debiteur.NomConjoint = "";
            Debiteur.DateMariage = null;
            Debiteur.LieuMariage = "";
            Debiteur.RegimeMatrim = "";
        }

        return Task.CompletedTask;
    }




}