@page "/Account/ChangePassword"
@layout EmptyLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using GesCPSI_Project.Models

@inject UserManager<UserModel> UserManager
@inject SignInManager<UserModel> SignInManager
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:linear-gradient(135deg,#0A2540 0%,#06182E 100%);">
    <div style="background:white;padding:48px 64px;border-radius:16px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <p style="margin-top:16px;font-size:1.1rem;font-weight:600;color:#0A2540;">Modification du mot de passe...</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Current { get; set; }
    [SupplyParameterFromQuery] public string? New { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is null)
        {
            Navigation.NavigateTo("/change-password?error=user", forceLoad: true);
            return;
        }

        // Récupérer l'utilisateur connecté
        var user = await UserManager.GetUserAsync(httpContext.User);
        if (user is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(Current) || string.IsNullOrWhiteSpace(New))
        {
            Navigation.NavigateTo("/change-password", forceLoad: true);
            return;
        }

        // Vérifier que le nouveau est différent de l'ancien
        if (Current == New)
        {
            Navigation.NavigateTo("/change-password?error=same", forceLoad: true);
            return;
        }

        // Effectuer le changement
        var result = await UserManager.ChangePasswordAsync(user, Current, New);

        if (!result.Succeeded)
        {
            // Identifier le type d'erreur
            if (result.Errors.Any(e => e.Code == "PasswordMismatch"))
            {
                Navigation.NavigateTo("/change-password?error=mismatch", forceLoad: true);
            }
            else
            {
                Navigation.NavigateTo("/change-password?error=weak", forceLoad: true);
            }
            return;
        }

        // ✅ Mot de passe changé : on désactive le flag MustChangePassword
        user.MustChangePassword = false;
        await UserManager.UpdateAsync(user);

        // Re-signer l'utilisateur pour rafraîchir les claims
        await SignInManager.RefreshSignInAsync(user);

        // Redirection vers la home
        Navigation.NavigateTo("/", forceLoad: true);
    }
}