@inherits LayoutComponentBase
@using MudBlazor


<MudLayout>
    <MudAppBar Elevation="0" Style="
           background:
           radial-gradient(900px 400px at 10% 0%, rgba(21,138,92,.18), transparent 60%),
           linear-gradient(135deg, #0A192F 0%, #004A88 100%);
           border-bottom: 1px solid rgba(255,255,255,0.08);
           ">

        <MudElement HtmlTag="a"
                    Class="ma-0"
                    Style="font-weight:bold; color: #EAFBF6; font-size: x-large; text-transform:none;"
                    href="/"
                    rel="noopener noreferrer">
            <MudImage Src="/Logo_boatg.jpg" Width="200" Height="50" Alt="Logo_boatg" Elevation="0" Align="left" LoadAsync="true" />
        </MudElement>
        <MudSpacer />
        @* <LoginDisplay /> *@
        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Style="color: #EAFBF6" Edge="Edge.End" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Style="background: transparent; border-right: none;">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Style="padding: 24px;">
            <MudPaper Elevation="0">
                @Body
            </MudPaper>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}


