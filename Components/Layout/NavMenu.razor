@using Microsoft.AspNetCore.Components.Authorization
@using GesCPSI_Project.Models

@inject AuthenticationStateProvider AuthStateProvider

<div class="sidebar">

    <!-- ============= HEADER (inchangé) ============= -->
    <div class="sidebar-header">
        <div class="brand-container">
            <div class="brand-info">
                <div class="brand-title">GESCPSI</div>
                <div class="brand-subtitle">Gestion des Actes juridiques (CPSI)</div>
            </div>
        </div>
    </div>

    <!-- ============= NAVIGATION ============= -->
    <div class="sidebar-nav">

        <!-- COMMUN À TOUS LES RÔLES -->
        <div class="nav-section">
            <div class="section-label">NAVIGATION</div>

            <NavLink class="nav-item" href="" Match="NavLinkMatch.All" title="Tableau de bord">
                <div class="nav-icon"><i class="bi bi-speedometer2"></i></div>
                <div class="nav-text">Tableau de bord</div>
            </NavLink>

            <NavLink class="nav-item" href="listAct" Match="NavLinkMatch.All" title="Consulter les actes">
                <div class="nav-icon"><i class="bi bi-folder2"></i></div>
                <div class="nav-text">Gestion des Actes</div>
            </NavLink>

            <!-- AGENT JURIDIQUE & ADMIN : saisie d'actes -->
            <AuthorizeView Roles="@($"{RoleNames.Admin},{RoleNames.Agent}")">
                <NavLink class="nav-item" href="choisirAct" Match="NavLinkMatch.Prefix" title="Saisir un nouvel acte">
                    <div class="nav-icon"><i class="bi bi-pencil-square"></i></div>
                    <div class="nav-text">Nouvel Acte</div>
                </NavLink>
            </AuthorizeView>

            <!-- RESPONSABLE JURIDIQUE & ADMIN : validation -->
            <AuthorizeView Roles="@($"{RoleNames.Admin},{RoleNames.Responsable}")">
                <NavLink class="nav-item" href="validationAct" Match="NavLinkMatch.All" title="Valider les actes">
                    <div class="nav-icon"><i class="bi bi-check2-circle"></i></div>
                    <div class="nav-text">Validation</div>
                </NavLink>
            </AuthorizeView>

            <NavLink class="nav-item" href="archivage" Match="NavLinkMatch.All" title="Archiver des actes">
                <div class="nav-icon"><i class="bi bi-archive"></i></div>
                <div class="nav-text">Archives</div>
            </NavLink>

            <!-- ADMIN UNIQUEMENT : historique complet et tests -->
            <AuthorizeView Roles="@RoleNames.Admin">
                <NavLink class="nav-item" href="securite" Match="NavLinkMatch.All" title="Historique et traçabilité">
                    <div class="nav-icon"><i class="bi bi-clock-history"></i></div>
                    <div class="nav-text">Historique</div>
                </NavLink>
            </AuthorizeView>
        </div>

        <!-- ADMINISTRATION : ADMIN UNIQUEMENT -->
        <AuthorizeView Roles="@RoleNames.Admin">
            <div class="nav-section">
                <div class="section-label">ADMINISTRATION</div>

                <NavLink class="nav-item" href="users" Match="NavLinkMatch.All" title="Gestion des utilisateurs">
                    <div class="nav-icon"><i class="bi bi-people-fill"></i></div>
                    <div class="nav-text">Utilisateurs</div>
                </NavLink>

                <NavLink class="nav-item" href="ajouterAct" Match="NavLinkMatch.All" title="Configurer les types d'actes">
                    <div class="nav-icon"><i class="bi bi-file-earmark-medical"></i></div>
                    <div class="nav-text">Types d'Actes</div>
                </NavLink>

                <NavLink class="nav-item" href="clientPage" Match="NavLinkMatch.Prefix" title="Gestion des clients">
                    <div class="nav-icon"><i class="bi bi-person-plus-fill"></i></div>
                    <div class="nav-text">Clients</div>
                </NavLink>

                <NavLink class="nav-item" href="/banque" Match="NavLinkMatch.All" title="Banque">
                    <div class="nav-icon"><i class="bi bi-bank"></i></div>
                    <div class="nav-text">Banque</div>
                </NavLink>

                <NavLink class="nav-item" href="parametres" Match="NavLinkMatch.All" title="Paramètres système">
                    <div class="nav-icon"><i class="bi bi-gear"></i></div>
                    <div class="nav-text">Paramètres</div>
                </NavLink>

                <NavLink class="nav-item" href="rapports" Match="NavLinkMatch.All" title="Rapports et statistiques">
                    <div class="nav-icon"><i class="bi bi-graph-up"></i></div>
                    <div class="nav-text">Rapports</div>
                </NavLink>
            </div>
        </AuthorizeView>

    </div>

    <!-- ============= FOOTER : USER PROFILE ============= -->
    <div class="sidebar-footer user-footer">
        <a href="/profile" class="user-profile footer-profile" title="Voir mon profil">
            <div class="avatar">
                <span class="avatar-initials">@_initials</span>
            </div>
            <div class="user-info">
                <div class="user-name">@_displayName</div>
                <div class="user-role">@_roleLabel</div>
            </div>
        </a>

        <a href="/Account/Logout" class="logout-btn" title="Déconnexion">
            <i class="bi bi-box-arrow-right"></i>
        </a>
    </div>
</div>

@code {
    private string _displayName = "Utilisateur";
    private string _initials = "U";
    private string _roleLabel = "—";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            // Email = UserName par défaut dans Identity
            var email = user.Identity.Name ?? "";

            // Récupère le claim "name" custom s'il existe, sinon utilise l'email
            _displayName = email.Contains('@') ? email.Split('@')[0] : email;

            // Génère les initiales (2 premières lettres en majuscule)
            _initials = string.IsNullOrEmpty(_displayName) ? "U"
                      : _displayName.Length >= 2 ? _displayName[..2].ToUpper()
                      : _displayName[..1].ToUpper();

            // Détermine le rôle prioritaire
            if (user.IsInRole(RoleNames.Admin))
                _roleLabel = "Administrateur";
            else if (user.IsInRole(RoleNames.Responsable))
                _roleLabel = "Resp. Juridique";
            else if (user.IsInRole(RoleNames.Agent))
                _roleLabel = "Agent Juridique";
        }
    }
}

<style>
    /* ====== VARIABLES ====== */
    :root {
        --sidebar-bg: linear-gradient(180deg, #0f2b5a 0%, #0a1a3a 100%);
        --sidebar-width: 46vh;
        --sidebar-collapsed: 40px;
        --primary-color: #4361ee;
        --primary-light: rgba(67, 97, 238, 0.15);
        --secondary-color: #3a0ca3;
        --accent-color: #4cc9f0;
        --success-color: #2ecc71;
        --text-primary: #ffffff;
        --text-secondary: #a0b4ff;
        --text-muted: #6c7db5;
        --border-color: rgba(255, 255, 255, 0.1);
        --shadow-sm: 0 4px 6px rgba(0, 0, 0, 0.1);
        --shadow-md: 0 10px 25px rgba(0, 0, 0, 0.2);
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    /* 🎨 CPSI - BOA Inspired Corporate Palette */
