        --cpsi-primary-blue: #1F3C88;
        --cpsi-white: #FFFFFF;
        --cpsi-light-gray: #F2F2F2;
        --cpsi-gray: #6C757D;
        --cpsi-dark-gray: #343A40;
        --cpsi-text-primary: #1E1E2D;
        --cpsi-text-secondary: var(--cpsi-gray);
        --cpsi-text-light: #FFFFFF;
        --cpsi-btn-primary: var(--cpsi-primary-green);
        --cpsi-btn-primary-hover: #126B49;
    }

    /* ====== SIDEBAR ====== */
    .sidebar {
        height: 100%;
        width: 100%;
        display: flex;
        flex-direction: column;
