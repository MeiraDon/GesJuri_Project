@page "/change-password"
@layout EmptyLayout
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Changer le mot de passe — GesCPSI</PageTitle>

<div class="change-pwd-page">
    <MudPaper Class="change-pwd-card" Elevation="0">
        <div class="change-pwd-header">
            <div class="change-pwd-icon">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="font-size: 3rem; color: #0A2540;" />
            </div>
            <MudText Typo="Typo.h4" Class="change-pwd-title">Changement de mot de passe</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                Pour votre sécurité, vous devez changer le mot de passe temporaire avant d'accéder à l'application.
            </MudText>
            @if (!string.IsNullOrEmpty(_userEmail))
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mt-3">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="me-1" />
                    @_userEmail
                </MudChip>
            }
        </div>

        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="change-pwd-form">
            <DataAnnotationsValidator />

            <div class="form-field">
                <MudTextField @bind-Value="model.CurrentPassword"
                              Label="Mot de passe actuel"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock"
                              AdornmentColor="Color.Primary"
                              InputType="@(_showCurrent ? InputType.Text : InputType.Password)"
                              Required="true"
                              Class="mb-3" />
                <div class="password-toggle">
                    <MudIconButton Icon="@(_showCurrent ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                   Size="Size.Small"
                                   OnClick="@(() => _showCurrent = !_showCurrent)" />
                </div>
            </div>

            <div class="form-field">
                <MudTextField @bind-Value="model.NewPassword"
                              Label="Nouveau mot de passe"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.LockOpen"
                              AdornmentColor="Color.Primary"
                              InputType="@(_showNew ? InputType.Text : InputType.Password)"
                              HelperText="8 caractères min, 1 majuscule, 1 minuscule, 1 chiffre"
                              Required="true"
                              Class="mb-3" />
                <div class="password-toggle">
                    <MudIconButton Icon="@(_showNew ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                   Size="Size.Small"
                                   OnClick="@(() => _showNew = !_showNew)" />
                </div>
            </div>

            <div class="form-field">
                <MudTextField @bind-Value="model.ConfirmPassword"
                              Label="Confirmer le nouveau mot de passe"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.LockOpen"
                              AdornmentColor="Color.Primary"
                              InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                              Required="true"
                              Class="mb-4" />
                <div class="password-toggle">
                    <MudIconButton Icon="@(_showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                   Size="Size.Small"
                                   OnClick="@(() => _showConfirm = !_showConfirm)" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error"
                          Icon="@Icons.Material.Filled.ErrorOutline"
                          Class="mb-3"
                          Dense="true">
                    @_errorMessage
                </MudAlert>
            }

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@_isLoading"
                       Class="change-pwd-submit-btn">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    <span>Modification en cours...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Save" Class="me-2" />
                    <span>Modifier le mot de passe</span>
                }
            </MudButton>
        </EditForm>

        <div class="change-pwd-footer">
            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" Href="/Account/Logout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="me-1" Size="Size.Small" />
                Se déconnecter
            </MudButton>
        </div>
    </MudPaper>
</div>

@code {
    public ChangePasswordModel model { get; set; } = new();

    [SupplyParameterFromQuery] public string? Error { get; set; }

    private string? _errorMessage;
    private string? _userEmail;
    private bool _isLoading;
    private bool _showCurrent;
    private bool _showNew;
    private bool _showConfirm;

    protected override async Task OnInitializedAsync()
    {
        // Récupérer l'email de l'utilisateur connecté pour l'afficher
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userEmail = authState.User.Identity?.Name;

        // Afficher les erreurs renvoyées par l'endpoint
        _errorMessage = Error switch
        {
            "mismatch" => "Le mot de passe actuel est incorrect.",
            "weak" => "Le nouveau mot de passe ne respecte pas les règles de sécurité.",
            "same" => "Le nouveau mot de passe doit être différent de l'ancien.",
            "user" => "Utilisateur introuvable.",
            _ => null
        };
    }

    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "Le mot de passe actuel est obligatoire")]
        public string CurrentPassword { get; set; } = "";

        [Required(ErrorMessage = "Le nouveau mot de passe est obligatoire")]
        [MinLength(8, ErrorMessage = "Le mot de passe doit faire au moins 8 caractères")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "La confirmation est obligatoire")]
        [Compare(nameof(NewPassword), ErrorMessage = "Les mots de passe ne correspondent pas")]
        public string ConfirmPassword { get; set; } = "";
    }

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        _isLoading = true;

        if (string.IsNullOrWhiteSpace(model.CurrentPassword) ||
            string.IsNullOrWhiteSpace(model.NewPassword) ||
            string.IsNullOrWhiteSpace(model.ConfirmPassword))
        {
            _errorMessage = "Veuillez remplir tous les champs.";
            _isLoading = false;
            return;
        }

        if (model.NewPassword != model.ConfirmPassword)
        {
            _errorMessage = "Les nouveaux mots de passe ne correspondent pas.";
            _isLoading = false;
            return;
        }

        // 🎯 On délègue à un endpoint Razor (qui peut écrire en BD avec contexte HTTP)
        var qs = $"?Current={Uri.EscapeDataString(model.CurrentPassword)}" +
                 $"&New={Uri.EscapeDataString(model.NewPassword)}";

        Navigation.NavigateTo($"/Account/ChangePassword{qs}", forceLoad: true);
        await Task.Yield();
    }
}

<style>
    .change-pwd-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0A2540 0%, #06182E 100%);
        padding: 24px;
    }

    .change-pwd-card {
        max-width: 520px;
        width: 100%;
        padding: 48px 40px;
        background: white !important;
        border-radius: 16px !important;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3) !important;
    }

    .change-pwd-header {
        text-align: center;
        margin-bottom: 36px;
    }

    .change-pwd-icon {
        margin-bottom: 16px;
    }

    .change-pwd-title {
        color: #0A2540 !important;
        font-weight: 700 !important;
    }

    .form-field {
        position: relative;
        margin-bottom: 4px;
    }

    .password-toggle {
        position: absolute;
        top: 12px;
        right: 8px;
        z-index: 2;
    }

    .change-pwd-submit-btn {
        padding: 14px !important;
        font-size: 1rem !important;
        font-weight: 600 !important;
        height: 52px !important;
        margin-top: 8px;
        text-transform: none !important;
        box-shadow: 0 4px 12px rgba(10, 37, 64, 0.15) !important;
    }

    .change-pwd-submit-btn:hover {
        box-shadow: 0 6px 16px rgba(10, 37, 64, 0.25) !important;
    }

    .change-pwd-footer {
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid #E1E4E8;
        text-align: center;
    }
</style>