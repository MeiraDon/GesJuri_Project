        color: #4B5563;
        margin-bottom: 6px;
    }

    .log-transition {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 6px 0;
    }

    .log-details {
        font-size: 0.85rem;
        color: #374151;
        background: #F8FAFC;
        padding: 8px 12px;
        border-radius: 6px;
        border-left: 3px solid #E1E4E8;
        margin-top: 6px;
    }

    /* ============ EMPTY STATE ============ */
    .empty-state {
        background: white !important;
        border: 1px solid #E1E4E8 !important;
        border-radius: 12px !important;
        padding: 60px 40px !important;
        text-align: center;
    }
</style>