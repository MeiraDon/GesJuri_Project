@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

@using GesCPSI_Project.Models
@using GesCPSI_Project.Interfaces
@using Microsoft.AspNetCore.Components.Authorization

@inject IDashboard DashboardService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Tableau de bord - GesCPSI</PageTitle>

<div class="dashboard-page">

    <!-- ═════════════ HEADER WELCOME ═════════════ -->
    <div class="welcome-bar">
        <div class="welcome-left">
            <div class="welcome-icon">👋</div>
            <div class="welcome-text">
                <div class="welcome-name">Bonjour @_displayName</div>
                <div class="welcome-role">@_roleLabel • BOA-TOGO</div>
            </div>
        </div>
        <div class="welcome-right">
            <div class="welcome-date">@_currentDate</div>
            <div class="welcome-greeting">@_greeting</div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-zone">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <!-- ═════════════ STAT CARDS (4 boxes) ═════════════ -->
        <div class="stat-grid">

            <div class="stat-box stat-total">
                <div class="stat-head">
                    <span class="stat-emoji">📋</span>
                    <span class="stat-number">@_stats.Total</span>
                </div>
                <div class="stat-label">Total</div>
                @if (_stats.TotalCeMois > 0)
                {
                    <div class="stat-trend trend-positive">+@_stats.TotalCeMois ce mois</div>
                }
                else
                {
                    <div class="stat-trend trend-empty">—</div>
                }
            </div>

            <div class="stat-box stat-pending">
                <div class="stat-head">
                    <span class="stat-emoji">⏳</span>
                    <span class="stat-number">@_stats.EnAttente</span>
                </div>
                <div class="stat-label">En attente</div>
                @if (_stats.EnAttenteUrgents > 0)
                {
                    <div class="stat-trend trend-urgent">⚠ @_stats.EnAttenteUrgents urgent</div>
                }
                else
                {
                    <div class="stat-trend trend-empty">—</div>
                }
            </div>

            <div class="stat-box stat-valid">
                <div class="stat-head">
                    <span class="stat-emoji">✅</span>
                    <span class="stat-number">@_stats.Valides</span>
                </div>
                <div class="stat-label">Validés</div>
                @if (_stats.ValidesCetteSemaine > 0)
                {
                    <div class="stat-trend trend-positive">+@_stats.ValidesCetteSemaine cette semaine</div>
                }
                else
                {
                    <div class="stat-trend trend-empty">—</div>
                }
            </div>

            <div class="stat-box stat-archive">
                <div class="stat-head">
                    <span class="stat-emoji">📦</span>
                    <span class="stat-number">@_stats.Archives</span>
                </div>
                <div class="stat-label">Archivés</div>
                <div class="stat-trend trend-empty">—</div>
            </div>

        </div>

        <!-- ═════════════ ROW : Graphique + À traiter ═════════════ -->
        <div class="main-row">

            <!-- GRAPHIQUE -->
            <div class="card chart-card">
                <div class="card-title">
                    <span class="card-emoji">📊</span>
                    <span>Évolution sur 6 mois</span>
                </div>
                <div class="card-body">
                    @if (_monthlyData.Any())
                    {
                        var maxValue = _monthlyData.Max(d => d.Count);
                        if (maxValue == 0)
                        {
                            maxValue = 1;
                        }

                        <div class="chart">
                            @foreach (var point in _monthlyData)
                            {
                                var heightPercent = (point.Count * 100.0 / maxValue);

                                <div class="chart-col">
                                    <div class="chart-value">@point.Count</div>
                                    <div class="chart-bar" style="height: @(heightPercent)%;"></div>
                                    <div class="chart-month">@point.Label</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-zone">
                            <span>Pas encore de données</span>
                        </div>
                    }
                </div>
            </div>

            <!-- A TRAITER -->
            <div class="card pending-card">
                <div class="card-title">
                    <span class="card-emoji">🎯</span>
                    <span>@(_isAgent ? "Mes brouillons" : "À valider")</span>
                    @if (_pendingActes.Any())
                    {
                        <span class="card-count">(@_pendingActes.Count en attente)</span>
                    }
                </div>
                <div class="card-body">
                    @if (!_pendingActes.Any())
                    {
                        <div class="empty-zone">
                            <span>✅ @(_isAgent ? "Aucun brouillon" : "Tout est à jour !")</span>
                        </div>
                    }
                    else
                    {
                        <div class="pending-rows">
                            @foreach (var item in _pendingActes)
                            {
                                <div class="pending-row @(item.IsUrgent ? "is-urgent" : "")" @onclick="@(() => GoToActe(item.IdActe))">
                                    <span class="pending-id">#@item.IdActe</span>
                                    <span class="pending-time">@item.WaitingTime</span>
                                    @if (item.IsUrgent)
                                    {
                                        <span class="pending-urgent">⚠️ Urgent</span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="card-footer-action">
                            <a @onclick="GoToAllPending" @onclick:preventDefault class="footer-link">
                                ─── Voir tous ───
                            </a>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- ═════════════ ACTIVITÉ RÉCENTE ═════════════ -->
        <div class="card activity-card">
            <div class="card-title">
                <span class="card-emoji">📜</span>
                <span>Activité récente</span>
            </div>
            <div class="card-body">
                @if (!_recentActivity.Any())
                {
                    <div class="empty-zone">
                        <span>Aucune activité récente</span>
                    </div>
                }
                else
                {
                    <div class="activity-rows">
                        @foreach (var activity in _recentActivity)
                        {
                            <div class="activity-row">
                                <span class="activity-dot" style="background: @GetActionColor(activity.Action);"></span>
                                <span class="activity-text">
                                    Acte <strong>#@activity.IdActe</strong>
                                    <span class="activity-action">@GetActionLabelLower(activity.Action)</span>
                                    @if (!string.IsNullOrEmpty(activity.UserName))
                                    {
                                        <span>par <strong>@activity.UserName</strong></span>
                                    }
                                </span>
                                <span class="activity-time">@activity.TimeAgo</span>
                            </div>
                        }
                    </div>
                    <div class="card-footer-action">
                        <a href="/historique" class="footer-link">
                            ─── Voir tout l'historique ───
                        </a>
                    </div>
                }
            </div>
        </div>

    }

</div>

@code {
    private DashboardStats _stats = new();
    private List<MonthlyDataPoint> _monthlyData = new();
    private List<PendingActeItem> _pendingActes = new();
    private List<RecentActivityItem> _recentActivity = new();

    private bool _loading = true;
    private int? _currentUserId;
    private bool _isAgent = false;
    private string _userRole = "";
    private string _displayName = "Utilisateur";
    private string _roleLabel = "";
    private string _greeting = "";
    private string _currentDate = "";

    protected override async Task OnInitializedAsync()
    {
        _currentDate = DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"));
        _currentDate = char.ToUpper(_currentDate[0]) + _currentDate.Substring(1);

        await IdentifyCurrentUserAsync();
        await LoadDashboardAsync();
    }

    private async Task IdentifyCurrentUserAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var email = user.Identity.Name ?? "";
            _displayName = email.Contains('@') ? email.Split('@')[0] : email;

            if (!string.IsNullOrEmpty(_displayName))
            {
                _displayName = char.ToUpper(_displayName[0]) + _displayName.Substring(1);
            }

            var nameIdentifier = user.Claims.FirstOrDefault(c => c.Type.Contains("nameidentifier"))?.Value;
            if (int.TryParse(nameIdentifier, out var id))
            {
                _currentUserId = id;
            }

            if (user.IsInRole(RoleNames.Admin))
            {
                _roleLabel = "Administrateur";
                _userRole = RoleNames.Admin;
            }
            else if (user.IsInRole(RoleNames.Responsable))
            {
                _roleLabel = "Responsable Juridique";
                _userRole = RoleNames.Responsable;
            }
            else if (user.IsInRole(RoleNames.Agent))
            {
                _roleLabel = "Agent Juridique";
                _userRole = RoleNames.Agent;
                _isAgent = true;
            }
        }

        var hour = DateTime.Now.Hour;
        if (hour < 12)
        {
            _greeting = "Bonne matinée";
        }
        else if (hour < 18)
        {
            _greeting = "Bonne après-midi";
        }
        else
        {
            _greeting = "Bonne soirée";
        }
    }

    private async Task LoadDashboardAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var restrictId = _isAgent ? _currentUserId : null;

            try
            {
                _stats = await DashboardService.GetStatsAsync(restrictId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[DASHBOARD] GetStatsAsync : {ex.Message}");
                _stats = new DashboardStats();
            }

            try
            {
                _monthlyData = await DashboardService.GetMonthlyEvolutionAsync(restrictId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[DASHBOARD] GetMonthlyEvolutionAsync : {ex.Message}");
                _monthlyData = new List<MonthlyDataPoint>();
            }

            try
            {
                _pendingActes = await DashboardService.GetPendingActesAsync(_userRole, _currentUserId, 5);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[DASHBOARD] GetPendingActesAsync : {ex.Message}");
                _pendingActes = new List<PendingActeItem>();
            }

            try
            {
                _recentActivity = await DashboardService.GetRecentActivityAsync(restrictId, 10);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[DASHBOARD] GetRecentActivityAsync : {ex.Message}");
                _recentActivity = new List<RecentActivityItem>();
            }
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void GoToActe(int acteId)
    {
        Navigation.NavigateTo("/listAct");
    }

    private void GoToAllPending()
    {
        if (_isAgent)
        {
            Navigation.NavigateTo("/listAct");
        }
        else
        {
            Navigation.NavigateTo("/validationAct");
        }
    }

    private string GetActionLabelLower(string action)
    {
        switch (action)
        {
            case "CREATION": return "créé";
            case "SOUMISSION": return "envoyé";
            case "VALIDATION": return "validé";
            case "REJET": return "rejeté";
            case "REOUVERTURE": return "ré-ouvert";
            case "ARCHIVAGE": return "archivé";
            default: return action.ToLower();
        }
    }

    private string GetActionColor(string action)
    {
        switch (action)
        {
            case "CREATION": return "#5E6B7D";
            case "SOUMISSION": return "#D97706";
            case "VALIDATION": return "#0E7C5C";
            case "REJET": return "#9B1C2D";
            case "REOUVERTURE": return "#D97706";
            case "ARCHIVAGE": return "#1F3C88";
            default: return "#5E6B7D";
        }
    }
}
