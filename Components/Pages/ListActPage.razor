@page "/listAct"
@rendermode InteractiveServer

<PageTitle>Gestion des Actes - Tableau de bord</PageTitle>

@using GesCPSI_Project.Models
@using GesCPSI_Project.Interfaces
@using GesCPSI_Project.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject ITypesAct TypesActService
@inject IClientAct ClientActService
@inject IRolesClientAct RolesClientActService
@inject IClient ClientService
@inject IAjoutAct AjoutActService
@inject ICautionnement CautionnementService
@inject IPret PretService
@inject ICharge ChargeService
@inject IAutorisation AutorisationService
@inject IEntiteJur EntiteJurService
@inject IActeWorkflow WorkflowService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.False" Class="py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            @* <MudText Typo="Typo.h4" Class="fw-bold text-gradient-primary mb-1">
                <i class="bi bi-folder2-open me-2"></i>Gestion des Actes
            </MudText> *@
            
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Gérez, suivez et reprenez vos actes (brouillon / validé).
            </MudText>
        </div>

        <div class="d-flex gap-2">
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => NavigationManager.NavigateTo("/choisirAct"))"
                       Class="px-4 rounded-pill">
                Nouvel acte
            </MudButton>

            <MudTooltip Text="Actualiser la liste">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Secondary"
                               Disabled="@_loading"
                               OnClick="ReloadAsync" /> @* Variant="Variant.Outlined" *@
            </MudTooltip>
        </div>
    </div>

    <!-- Stats -->
    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-2-4 col-sm-6">
            <MudPaper Class="p-3 h-100 shadow-sm hover-lift" Elevation="1">
                <div class="d-flex align-items-center">
                    <div class="icon-stat bg-secondary-light p-2 rounded-circle me-3">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Secondary" />
                    </div>
                    <div>
                        <div class="text-muted small">Total</div>
                        <div class="h4 fw-bold text-primary mb-0">@_actes.Count</div>
                    </div>
                </div>
            </MudPaper>
        </div>

        <div class="col-md-2-4 col-sm-6">
            <MudPaper Class="p-3 h-100 shadow-sm hover-lift" Elevation="1">
                <div class="d-flex align-items-center">
                    <div class="icon-stat bg-default-light p-2 rounded-circle me-3">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Default" />
                    </div>
                    <div>
                        <div class="text-muted small">Brouillons</div>
                        <div class="h4 fw-bold mb-0" style="color:#5E6B7D;">
                            @_actes.Count(a => a.StatutWorkflow == ActeStatut.Brouillon)
                        </div>
                    </div>
                </div>
            </MudPaper>
        </div>

        <div class="col-md-2-4 col-sm-6">
            <MudPaper Class="p-3 h-100 shadow-sm hover-lift" Elevation="1">
                <div class="d-flex align-items-center">
                    <div class="icon-stat bg-warning-light p-2 rounded-circle me-3">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Warning" />
                    </div>
                    <div>
                        <div class="text-muted small">En attente</div>
                        <div class="h4 fw-bold text-warning mb-0">
                            @_actes.Count(a => a.StatutWorkflow == ActeStatut.EnAttenteValidation)
                        </div>
                    </div>
                </div>
            </MudPaper>
        </div>

        <div class="col-md-2-4 col-sm-6">
            <MudPaper Class="p-3 h-100 shadow-sm hover-lift" Elevation="1">
                <div class="d-flex align-items-center">
                    <div class="icon-stat bg-success-light p-2 rounded-circle me-3">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                    </div>
                    <div>
                        <div class="text-muted small">Validés</div>
                        <div class="h4 fw-bold text-success mb-0">
                            @_actes.Count(a => a.StatutWorkflow == ActeStatut.Valide)
                        </div>
                    </div>
                </div>
            </MudPaper>
        </div>

        <div class="col-md-2-4 col-sm-6">
            <MudPaper Class="p-3 h-100 shadow-sm hover-lift" Elevation="1">
                <div class="d-flex align-items-center">
                    <div class="icon-stat bg-error-light p-2 rounded-circle me-3">
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                    </div>
                    <div>
                        <div class="text-muted small">Rejetés</div>
                        <div class="h4 fw-bold text-error mb-0">
                            @_actes.Count(a => a.StatutWorkflow == ActeStatut.Rejete)
                        </div>
                    </div>
                </div>
            </MudPaper>
        </div>
    </div>

    <!-- Tabs -->
    <MudPaper Class="mb-3" Elevation="1">
        <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Color="Color.Primary">
            <MudTabPanel Text="Tous" />
            <MudTabPanel Text="Brouillons" />
            <MudTabPanel Text="En attente" />
            <MudTabPanel Text="Validés" />
            <MudTabPanel Text="Rejetés" />
            <MudTabPanel Text="Archivés" />
        </MudTabs>

        <!-- Filters -->
        <div class="p-3 border-top">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <MudTextField @bind-Value="_search"
                                  Placeholder="Rechercher (ID, type, débiteur...)"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  FullWidth="true" />
                </div>

                <div class="col-md-4">
                    <MudSelect T="ActeStatut?" @bind-Value="_statutFilterEnum"
                               Variant="Variant.Outlined"
                               Label="Statut"
                               Clearable="true"
                               FullWidth="true">
                        <MudSelectItem T="ActeStatut?" Value="@((ActeStatut?)null)">Tous les statuts</MudSelectItem>
                        <MudSelectItem T="ActeStatut?" Value="@((ActeStatut?)ActeStatut.Brouillon)">Brouillon</MudSelectItem>
                        <MudSelectItem T="ActeStatut?" Value="@((ActeStatut?)ActeStatut.EnAttenteValidation)">En attente</MudSelectItem>
                        <MudSelectItem T="ActeStatut?" Value="@((ActeStatut?)ActeStatut.Valide)">Validé</MudSelectItem>
                        <MudSelectItem T="ActeStatut?" Value="@((ActeStatut?)ActeStatut.Rejete)">Rejeté</MudSelectItem>
                        <MudSelectItem T="ActeStatut?" Value="@((ActeStatut?)ActeStatut.Archive)">Archivé</MudSelectItem>
                    </MudSelect>
                </div>

                <div class="col-md-4">
                    <MudSelect T="int?" @bind-Value="_selectedTypeId"
                               Variant="Variant.Outlined"
                               Label="Type d'acte"
                               Clearable="true"
                               FullWidth="true">

                        <MudSelectItem T="int?" Value="@((int?)null)">Tous les types</MudSelectItem>

                        @foreach (var type in _acteTypes)
                        {
                            <MudSelectItem T="int?" Value="@((int?)type.IdAjout)">
                                @type.NomAct
                            </MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <MudSwitch @bind-Value="_showOnlyMine"
                               Color="Color.Primary"
                               Label="Voir uniquement mes actes" />

                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ResetFilters">
                        Effacer filtres
                    </MudButton>
                </div>
            </div>
        </div>
    </MudPaper>

    @if (_loading)
    {
        <div class="text-center py-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <div class="text-muted mt-3">Chargement des actes...</div>
        </div>
    }
    else if (!FilteredActes.Any())
    {
        <div class="text-center py-5 my-4">
            <i class="bi bi-folder-x display-1 text-muted"></i>
            <div class="h5 fw-bold mt-3">Aucun acte trouvé</div>
            <div class="text-muted mb-3">Change les filtres ou crée un nouvel acte.</div>
            <MudButton Color="Color.Primary" Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => NavigationManager.NavigateTo("/choisirAct"))">
                Créer un acte
            </MudButton>
        </div>
    }
    else
    {
        <MudPaper Class="overflow-hidden shadow-sm rounded-3" Elevation="2">
            <MudTable Items="FilteredActes"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      FixedHeader="true"
                      Height="520px"
                      Breakpoint="Breakpoint.Sm"
                      RowsPerPage="10">
                <HeaderContent>
                    
                    <MudTh>Date Création</MudTh>
                    <MudTh>Dernière Modification</MudTh>
                    <MudTh>Types Actes</MudTh>
                    <MudTh>Débiteur</MudTh>
                    <MudTh>Caution</MudTh>
                    <MudTh>Statut</MudTh>
                    <MudTh class="text-end">Actions</MudTh>
                </HeaderContent>

                <RowTemplate Context="acte">
                   
                    <MudTd>

                        <div class="text-nowrap">@acte.DateCreation.ToLocalTime().ToString("dd/MM/yyyy")</div>
                        <div class="text-muted small">@acte.DateCreation.ToLocalTime().ToString("HH:mm")</div>
                    </MudTd>

                    <MudTd>
                        <div class="text-nowrap">@acte.DateMaj.ToLocalTime().ToString("dd/MM/yyyy")</div>
                        <div class="text-muted small">@acte.DateMaj.ToLocalTime().ToString("HH:mm")</div>
                    </MudTd>

                    <MudTd>
                        <div class="fw-medium">@acte.NomTypesActe</div>
                    </MudTd>

                    <MudTd>
                        <div class="fw-medium participant-cell">@GetDebiteurName(acte.IdActe)</div>
                    </MudTd>

                    <MudTd>
                        <div class="fw-medium participant-cell">@GetCautionName(acte.IdActe)</div>
                    </MudTd>

                    <MudTd>
                        <div class="d-flex align-items-center gap-1">
                            <ActeStatutBadge Statut="acte.StatutWorkflow" />

                            @* Tooltip pour montrer le motif de rejet si l'acte est rejeté *@
                            @if (acte.StatutWorkflow == ActeStatut.Rejete && !string.IsNullOrWhiteSpace(acte.MotifRejet))
                            {
                                <MudTooltip Text="@($"Motif : {acte.MotifRejet}")" Placement="Placement.Top">
                                    <MudIcon Icon="@Icons.Material.Filled.Info"
                                             Size="Size.Small"
                                             Color="Color.Error" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>

                    <MudTd class="text-end">
                        <div class="d-inline-flex align-items-center gap-1">

                            <!-- 👁️ APERÇU - toujours visible -->
                            <MudTooltip Text="Aperçu de l'acte">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               OnClick="@(() => PreviewActe(acte))" />
                            </MudTooltip>

                            <!-- ✏️ MODIFIER -->
                            <MudTooltip Text="@(CanEditActe(acte) ? "Modifier" : "Modification impossible (acte en cours de validation ou validé)")">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Disabled="@(!CanEditActe(acte))"
                                               OnClick="@(() => Edit(acte))" />
                            </MudTooltip>

                            <!-- ⬇️ TÉLÉCHARGER PDF - si PdfGenerePath existe -->
                            @if (!string.IsNullOrWhiteSpace(acte.PdfGenerePath))
                            {
                                <MudTooltip Text="@($"PDF officiel généré le {acte.DateGenerationPdf?.ToLocalTime():dd/MM/yyyy HH:mm}")">
                                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                   Color="Color.Success"
                                                   Size="Size.Small"
                                                   OnClick="@(() => DownloadPdf(acte))" />
                                </MudTooltip>
                            }

                            <!-- 📤 UPLOADER SIGNATURE - si Validé et pas encore archivé -->
                            @if (acte.StatutWorkflow == ActeStatut.Valide)
                            {
                                <AuthorizeView Roles="@($"{RoleNames.Admin},{RoleNames.Responsable}")">
                                    <MudTooltip Text="Téléverser le document signé">
                                        <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                                                       Color="Color.Tertiary"
                                                       Size="Size.Small"
                                                       OnClick="@(() => OpenUploadDialogAsync(acte))" />
                                    </MudTooltip>
                                </AuthorizeView>
                            }

                            <!-- 📄 VOIR PDF SIGNÉ - si archivé -->
                            @if (acte.StatutWorkflow == ActeStatut.Archive && !string.IsNullOrWhiteSpace(acte.PdfSignePath))
                            {
                                <MudTooltip Text="Voir le PDF signé archivé">
                                    <MudIconButton Icon="@Icons.Material.Filled.VerifiedUser"
                                                   Color="Color.Info"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenSignedPdf(acte))" />
                                </MudTooltip>
                            }

                            <!-- 📤 ENVOYER -->
                            <MudTooltip Text="Envoyer au responsable">
                                <MudIconButton Icon="@Icons.Material.Filled.Send"
                                               Color="Color.Info"
                                               Size="Size.Small"
                                               Disabled="@(_loading || !CanSendActe(acte))"
                                               OnClick="@(() => SendActeAsync(acte))" />
                            </MudTooltip>

                            <!-- ↻ RÉ-OUVRIR un acte rejeté -->
                            @if (acte.StatutWorkflow == ActeStatut.Rejete)
                            {
                                <MudTooltip Text="Ré-ouvrir l'acte pour modification">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   Disabled="@_loading"
                                                   OnClick="@(() => RouvrirActeAsync(acte))" />
                                </MudTooltip>
                            }

                            <!-- 🗑️ SUPPRIMER -->
                            <MudTooltip Text="@(CanDeleteActe(acte) ? "Supprimer" : "Suppression impossible")">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Disabled="@(!CanDeleteActe(acte))"
                                               OnClick="@(() => ConfirmDelete(acte))" />
                            </MudTooltip>

                        </div>
                    </MudTd>

                </RowTemplate>

                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }

</MudContainer>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private List<TypesActModel> _actes = new();
    private bool _loading = true;

    private bool _showOnlyMine = false;
    private int? _currentUserId;
    private bool _isAgent = false;

    private string _search = "";
    private ActeStatut? _statutFilterEnum = null;
    private string? _statutFilter = null; // (gardé pour compat, mais inutilisé)
    private int? _selectedTypeId = null;
    private int _activeTabIndex = 0;

    private List<AjoutActModel> _acteTypes = new();

    private Dictionary<int, string> _debiteurs = new();
    private Dictionary<int, string> _cautions = new();

    private List<TypesActModel> FilteredActes => GetFilteredActes();

    protected override async Task OnInitializedAsync()
    {
        await IdentifyCurrentUserAsync();
        await LoadDataAsync();
    }

    private async Task IdentifyCurrentUserAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            // Récupère l'ID via le claim NameIdentifier
            var nameIdentifier = user.Claims
                .FirstOrDefault(c => c.Type.Contains("nameidentifier"))?.Value;

            if (int.TryParse(nameIdentifier, out var id))
                _currentUserId = id;

            // Si l'utilisateur est un Agent, on coche "Mes actes" par défaut
            _isAgent = user.IsInRole(RoleNames.Agent);
            if (_isAgent)
                _showOnlyMine = true;
        }
    }

    private bool _disposed;
    private CancellationTokenSource? _cts = new CancellationTokenSource();

    [Parameter, SupplyParameterFromQuery(Name = "refresh")]
    public int? Refresh { get; set; }


    protected override async Task OnParametersSetAsync()
    {
        if (Refresh == 1)
        {
            await LoadDataAsync();

            // ✅ Nettoyage: évite refresh infini au F5
            NavigationManager.NavigateTo("/listAct", replace: true);
        }
    }

    private static string FormatClientDisplay(ClientModel? client)
    {
        if (client is null)
            return "Non spécifié";

        if (string.Equals(client.TypeClient, "Personne Morale", StringComparison.OrdinalIgnoreCase))
        {
            var lignes = new List<string>();

            if (!string.IsNullOrWhiteSpace(client.NomRaisonsociale))
                lignes.Add(client.NomRaisonsociale.Trim());
            else
                lignes.Add("Personne morale");

            if (!string.IsNullOrWhiteSpace(client.NomRepresentant))
                lignes.Add($"Représentant : {client.NomRepresentant.Trim()}");

            if (!string.IsNullOrWhiteSpace(client.NumCompte))
                lignes.Add($"Compte : {client.NumCompte.Trim()}");

            return string.Join("\n", lignes);
        }
        else
        {
            var lignes = new List<string>();

            var nomComplet = $"{client.Nom} {client.Prenoms}".Trim();

            if (!string.IsNullOrWhiteSpace(nomComplet))
                lignes.Add(nomComplet);
            else if (!string.IsNullOrWhiteSpace(client.NomRepresentant))
                lignes.Add(client.NomRepresentant.Trim());
            else
                lignes.Add("Personne physique");

            if (!string.IsNullOrWhiteSpace(client.NumCompte))
                lignes.Add($"Compte : {client.NumCompte.Trim()}");

            return string.Join("\n", lignes);
        }
    }

    public void Dispose()
    {
        _disposed = true;
        try { _cts?.Cancel(); } catch { }
        _cts?.Dispose();
    }

    private Task SafeStateHasChanged()
    {
        if (_disposed) return Task.CompletedTask;
        return InvokeAsync(StateHasChanged);
    }

    private readonly SemaphoreSlim _loadLock = new(1, 1);

    private async Task LoadDataAsync()
    {
        await _loadLock.WaitAsync();
        try
        {
            _loading = true;
            await SafeStateHasChanged();

            // ✅ IMPORTANT : séquentiel (pas de WhenAll, pas de tasks EF en parallèle)
            _actes = await TypesActService.GetAllAsync() ?? new List<TypesActModel>();
            _acteTypes = await AjoutActService.GetAllAsync() ?? new List<AjoutActModel>();

            await LoadActeParticipantsAsync();
        }
        catch (OperationCanceledException)
        {
            // normal si tu quittes la page
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            _loadLock.Release();
            await SafeStateHasChanged();
        }
    }

    private async Task ReloadAsync()
    {
        await LoadDataAsync();
        Snackbar.Add("Liste actualisée", Severity.Success);
    }

    private async Task LoadActeParticipantsAsync()
    {
        var links = await ClientActService.GetAllAsync() ?? new List<ClientActModel>();
        var roles = await RolesClientActService.GetAllAsync() ?? new List<RolesClientActModel>();
        var clients = await ClientService.GetAllAsync() ?? new List<ClientModel>();

        var roleDebiteurIds = roles
            .Where(r => !string.IsNullOrWhiteSpace(r.Libelle) &&
                        (string.Equals(r.Libelle.Trim(), "Debiteur", StringComparison.OrdinalIgnoreCase) ||
                         string.Equals(r.Libelle.Trim(), "Débiteur", StringComparison.OrdinalIgnoreCase)))
            .Select(r => r.IdRole)
            .ToHashSet();

        var roleCautionIds = roles
            .Where(r => !string.IsNullOrWhiteSpace(r.Libelle) &&
                        string.Equals(r.Libelle.Trim(), "Caution", StringComparison.OrdinalIgnoreCase))
            .Select(r => r.IdRole)
            .ToHashSet();

        _debiteurs.Clear();
        _cautions.Clear();

        foreach (var link in links)
        {
            var client = clients.FirstOrDefault(c => c.IdClt == link.IdClt);
            var display = FormatClientDisplay(client);

            if (roleDebiteurIds.Contains(link.IdRole) && !_debiteurs.ContainsKey(link.IdActe))
            {
                _debiteurs[link.IdActe] = display;
            }

            if (roleCautionIds.Contains(link.IdRole) && !_cautions.ContainsKey(link.IdActe))
            {
                _cautions[link.IdActe] = display;
            }
        }
    }

    private List<TypesActModel> GetFilteredActes()
    {
        IEnumerable<TypesActModel> filtered = _actes;

        // Tabs (5 panneaux)
        filtered = _activeTabIndex switch
        {
            1 => filtered.Where(a => a.StatutWorkflow == ActeStatut.Brouillon),
            2 => filtered.Where(a => a.StatutWorkflow == ActeStatut.EnAttenteValidation),
            3 => filtered.Where(a => a.StatutWorkflow == ActeStatut.Valide),
            4 => filtered.Where(a => a.StatutWorkflow == ActeStatut.Rejete),
            5 => filtered.Where(a => a.StatutWorkflow == ActeStatut.Archive),
            _ => filtered
        };

        // Filtre Statut (combobox)
        if (_statutFilterEnum.HasValue)
            filtered = filtered.Where(a => a.StatutWorkflow == _statutFilterEnum.Value);

        // Filtre "Mes actes" (uniquement pour Agent — Admin et Responsable voient tout)
        if (_showOnlyMine && _currentUserId.HasValue)
            filtered = filtered.Where(a => a.IdUser == _currentUserId.Value);

        // Type
        if (_selectedTypeId.HasValue)
            filtered = filtered.Where(a => a.IdAjout == _selectedTypeId.Value);

        // Search
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim().ToLowerInvariant();
            filtered = filtered.Where(a =>
                a.IdActe.ToString().Contains(s) ||
                (a.NomTypesActe ?? "").ToLowerInvariant().Contains(s) ||
                ActeStatutHelper.GetLabel(a.StatutWorkflow).ToLowerInvariant().Contains(s) ||
                GetDebiteurName(a.IdActe).ToLowerInvariant().Contains(s) ||
                GetCautionName(a.IdActe).ToLowerInvariant().Contains(s));
        }

        return filtered.OrderByDescending(a => a.DateMaj).ToList();
    }

    private string GetDebiteurName(int acteId)
        => _debiteurs.TryGetValue(acteId, out var name) ? name : "Non spécifié";

    private string GetCautionName(int acteId)
        => _cautions.TryGetValue(acteId, out var name) ? name : "Non spécifié";



    private void ResetFilters()
    {
        _search = "";
        _statutFilter = null;
        _statutFilterEnum = null;
        _selectedTypeId = null;
        _activeTabIndex = 0;
        StateHasChanged();
    }

    // private void Edit(TypesActModel acte)
    //     => NavigationManager.NavigateTo($"/saisirPage/{acte.IdAjout}?acteId={acte.IdActe}");

    private void Edit(TypesActModel acte)
    {
        var returnUrl = Uri.EscapeDataString("/listAct");
        NavigationManager.NavigateTo($"/saisirPage/{acte.IdAjout}?acteId={acte.IdActe}&returnUrl={returnUrl}");
    }

    

    private async Task PreviewActe(TypesActModel acte)
    {
        var parameters = new DialogParameters
    {
        { nameof(GesCPSI_Project.Components.Dialogs.ActePreviewDialog.ActeId), acte.IdActe }
    };

        var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                BackdropClick = true,
                Position = DialogPosition.Center
            };

        await DialogService.ShowAsync<GesCPSI_Project.Components.Dialogs.ActePreviewDialog>(
            "Aperçu", parameters, options);
    }

    private async Task DownloadPdf(TypesActModel acte)
    {
        if (string.IsNullOrWhiteSpace(acte.PdfGenerePath))
        {
            Snackbar.Add("Le PDF n'a pas encore été généré pour cet acte.", Severity.Warning);
            return;
        }

        try
        {
            // Le chemin est déjà au format /uploads/actes/pdf/xxx.pdf (web-relative)
            var url = acte.PdfGenerePath.StartsWith("/") ? acte.PdfGenerePath : "/" + acte.PdfGenerePath;

            // Ouverture dans un nouvel onglet → le navigateur propose le téléchargement
            await JS.InvokeVoidAsync("open", url, "_blank");

            Snackbar.Add($"Téléchargement de l'acte #{acte.IdActe} en cours...", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur téléchargement : {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteActeCascadeAsync(int acteId)
    {
        // 1) supprimer les sous-entités 1-1 liées à l'acte
        var cautions = await CautionnementService.GetAllAsync() ?? new();
        var caution = cautions.FirstOrDefault(x => x.IdActe == acteId);
        if (caution != null) await CautionnementService.DeleteAsync(caution);

        var prets = await PretService.GetAllAsync() ?? new();
        var pret = prets.FirstOrDefault(x => x.IdActe == acteId);
        if (pret != null) await PretService.DeleteAsync(pret);

        var autos = await AutorisationService.GetAllAsync() ?? new();
        var auto = autos.FirstOrDefault(x => x.IdActe == acteId);
        if (auto != null) await AutorisationService.DeleteAsync(auto);

        var charges = await ChargeService.GetAllAsync() ?? new();
        var charge = charges.FirstOrDefault(x => x.IdActe == acteId);
        if (charge != null) await ChargeService.DeleteAsync(charge);

        var ents = await EntiteJurService.GetAllAsync() ?? new();
        var ent = ents.FirstOrDefault(x => x.IdActe == acteId);
        if (ent != null) await EntiteJurService.DeleteAsync(ent);

        // 2) supprimer les liaisons ClientAct
        var links = await ClientActService.GetAllAsync() ?? new();
        var toDeleteLinks = links.Where(x => x.IdActe == acteId).ToList();
        foreach (var l in toDeleteLinks)
            await ClientActService.DeleteAsync(l);

        // 3) supprimer l'acte lui-même
        await TypesActService.DeleteByIdAsync(acteId);
    }

    private bool CanSendActe(TypesActModel acte)
    {
        // L'agent peut envoyer ses actes en Brouillon ou ré-envoyer un acte Rejeté
        return acte.StatutWorkflow == ActeStatut.Brouillon
            || acte.StatutWorkflow == ActeStatut.Rejete;
    }

    private bool CanEditActe(TypesActModel acte)
    {
        // On ne peut éditer que les actes en Brouillon ou Rejeté
        return acte.StatutWorkflow == ActeStatut.Brouillon
            || acte.StatutWorkflow == ActeStatut.Rejete;
    }

    private bool CanDeleteActe(TypesActModel acte)
    {
        // On ne peut supprimer que les actes en Brouillon
        return acte.StatutWorkflow == ActeStatut.Brouillon;
    }

    private async Task SendActeAsync(TypesActModel acte)
    {
        if (_loading) return;

        if (acte.StatutWorkflow != ActeStatut.Brouillon && acte.StatutWorkflow != ActeStatut.Rejete)
        {
            Snackbar.Add("Cet acte ne peut pas être envoyé en validation depuis son statut actuel.", Severity.Warning);
            return;
        }

        var motifText = acte.StatutWorkflow == ActeStatut.Rejete && !string.IsNullOrWhiteSpace(acte.MotifRejet)
            ? $"\n\n⚠️ Cet acte avait été rejeté.\nMotif précédent : {acte.MotifRejet}\nAssurez-vous que les corrections ont été apportées."
            : "";

        var ok = await DialogService.ShowMessageBox(
            "Envoyer l'acte en validation ?",
            $"L'acte #{acte.IdActe} sera envoyé au Responsable Juridique pour validation.{motifText}\n\nVous ne pourrez plus le modifier tant qu'il n'aura pas été validé ou rejeté.",
            yesText: "Envoyer",
            cancelText: "Annuler");

        if (ok != true) return;

        try
        {
            _loading = true;
            await SafeStateHasChanged();

            var userId = await GetCurrentUserIdAsync();
            if (userId is null)
            {
                Snackbar.Add("Impossible d'identifier votre compte. Reconnectez-vous.", Severity.Error);
                return;
            }

            var result = await WorkflowService.SoumettreAsync(acte.IdActe, userId.Value);

            if (!result.Success)
            {
                Snackbar.Add(result.ErrorMessage ?? "Erreur lors de l'envoi.", Severity.Error);
                return;
            }

            Snackbar.Add($"Acte #{acte.IdActe} envoyé en validation au Responsable Juridique.", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            await SafeStateHasChanged();
        }
    }

    private async Task ConfirmDelete(TypesActModel acte)
    {
        var ok = await DialogService.ShowMessageBox(
            "Suppression",
            $"Supprimer définitivement l'acte #{acte.IdActe} ?\n\nCette action est irréversible.",
            yesText: "Supprimer",
            cancelText: "Annuler");

        if (ok != true) return;

        try
        {
            _loading = true;
            await SafeStateHasChanged();

            await DeleteActeCascadeAsync(acte.IdActe);

            Snackbar.Add($"Acte #{acte.IdActe} supprimé.", Severity.Success);

            // ✅ refresh local rapide
            _actes.RemoveAll(a => a.IdActe == acte.IdActe);
            _debiteurs.Remove(acte.IdActe);
            _cautions.Remove(acte.IdActe);

            await SafeStateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur suppression : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            await SafeStateHasChanged();
        }
    }

    private Color GetStatusColor(string? statut) => statut switch
    {
        "Brouillon" => Color.Warning,
        "EnAttenteEnvoi" => Color.Primary,
        "Envoye" => Color.Success,
        _ => Color.Default
    };

    private async Task RouvrirActeAsync(TypesActModel acte)
    {
        if (_loading) return;

        if (acte.StatutWorkflow != ActeStatut.Rejete)
        {
            Snackbar.Add("Seul un acte rejeté peut être ré-ouvert.", Severity.Warning);
            return;
        }

        var motifText = !string.IsNullOrWhiteSpace(acte.MotifRejet)
            ? $"\n\n💬 Motif du rejet : {acte.MotifRejet}"
            : "";

        var ok = await DialogService.ShowMessageBox(
            "Ré-ouvrir l'acte ?",
            $"L'acte #{acte.IdActe} repassera en Brouillon. Vous pourrez le modifier et le renvoyer en validation.{motifText}",
            yesText: "Ré-ouvrir",
            cancelText: "Annuler");

        if (ok != true) return;

        try
        {
            _loading = true;
            await SafeStateHasChanged();

            var userId = await GetCurrentUserIdAsync();
            if (userId is null)
            {
                Snackbar.Add("Impossible d'identifier votre compte.", Severity.Error);
                return;
            }

            var result = await WorkflowService.RouvrirAsync(acte.IdActe, userId.Value);

            if (!result.Success)
            {
                Snackbar.Add(result.ErrorMessage ?? "Erreur lors de la ré-ouverture.", Severity.Error);
                return;
            }

            Snackbar.Add($"Acte #{acte.IdActe} ré-ouvert. Vous pouvez maintenant le modifier.", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            await SafeStateHasChanged();
        }
    }

    private async Task OpenUploadDialogAsync(TypesActModel acte)
    {
        if (_currentUserId is null)
        {
            Snackbar.Add("Impossible d'identifier votre compte.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters
            {
                ["Acte"] = acte,
                ["CurrentUserId"] = _currentUserId.Value
            };

        var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseOnEscapeKey = false
            };

        var dialog = await DialogService.ShowAsync<GesCPSI_Project.Components.Dialogs.UploadSignedActeDialog>(
            "Téléverser le document signé", parameters, options);

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadDataAsync();
        }
    }

    private async Task OpenSignedPdf(TypesActModel acte)
    {
        if (string.IsNullOrWhiteSpace(acte.PdfSignePath))
        {
            Snackbar.Add("Aucun PDF signé disponible.", Severity.Warning);
            return;
        }

        try
        {
            var url = acte.PdfSignePath.StartsWith("/") ? acte.PdfSignePath : "/" + acte.PdfSignePath;
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
    }

    private Task<int?> GetCurrentUserIdAsync()
    {
        return Task.FromResult(_currentUserId);
    }

