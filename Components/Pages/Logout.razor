@page "/logout"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<div class="logout-page">
    <MudPaper Class="logout-card" Elevation="0">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4" Style="color: #0A2540; font-weight: 600;">
            Déconnexion en cours...
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            À bientôt sur GesCPSI
        </MudText>
    </MudPaper>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Petite pause pour que l'utilisateur voie la transition
        await Task.Delay(1200);

        // Puis on déclenche le vrai logout (qui efface le cookie côté serveur)
        Navigation.NavigateTo("/Account/Logout", forceLoad: true);
    }
}

<style>
    .logout-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0A2540 0%, #06182E 100%);
    }

    .logout-card {
        background: white !important;
        padding: 48px 64px !important;
        border-radius: 16px !important;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3) !important;
    }
</style>