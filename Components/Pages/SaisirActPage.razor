private static string DisplayClientName(ClientModel c)
{
    // Personne morale : raison sociale + représentant (si dispo)
    if (!string.IsNullOrWhiteSpace(c.NomRaisonsociale))
    {
        var rep = string.IsNullOrWhiteSpace(c.NomRepresentant) ? "" : $" — Rep: {c.NomRepresentant}";
        return $"{c.NomRaisonsociale}{rep}";
    }

    // Personne physique
    return $"{c.Nom} {c.Prenoms}".Trim();
}

// =================== PARTICIPANTS ACTIONS ===================

private void ClearParticipant(ParticipantRole role)
{
    participants[role].ClientId = null;
    participants[role].Selected = null;
    participants[role].Results.Clear();
    participants[role].InfoMessage = null;
}

private async Task SearchClientsAsync(ParticipantRole role)
{
    var ps = participants[role];
    ps.InfoMessage = null;
    ps.Results.Clear();

    var q = (ps.Search ?? "").Trim();
    if (string.IsNullOrWhiteSpace(q) || q.Length < 2)
    {
        ps.InfoMessage = "Saisissez au moins 2 caractères.";
        return;
    }

    try
    {
        ps.IsSearching = true;

        var all = await ClientService.GetAllAsync() ?? new List<ClientModel>();
        var qq = q.ToLowerInvariant();

        ps.Results = all.Where(c =>
                (DisplayClientName(c).ToLowerInvariant().Contains(qq)) ||
                (!string.IsNullOrWhiteSpace(c.TelCel) && c.TelCel.ToLowerInvariant().Contains(qq)) ||
                (!string.IsNullOrWhiteSpace(c.TelBur) && c.TelBur.ToLowerInvariant().Contains(qq)) ||
                (!string.IsNullOrWhiteSpace(c.TypePieceID) && c.TypePieceID.ToLowerInvariant().Contains(qq)) ||
                (!string.IsNullOrWhiteSpace(c.NumPieceID) && c.NumPieceID.ToLowerInvariant().Contains(qq))
            )
            .OrderBy(c => DisplayClientName(c))
            .ToList();

        if (ps.Results.Count == 0)
            ps.InfoMessage = "Client introuvable.";
    }
    catch (Exception ex)
    {
        ps.InfoMessage = $"Erreur recherche: {ex.Message}";
    }
    finally
    {
        ps.IsSearching = false;
    }
}

private void SelectClient(ParticipantRole role, ClientModel client)
{
    participants[role].Selected = client;
    participants[role].ClientId = client.IdClt;
    participants[role].Results.Clear();
    participants[role].InfoMessage = null;
}

private async Task OpenCreateClientDialogAsync(ParticipantRole role)
{
    // ⚠️ Tu peux garder ce code : il suppose un composant dialog réutilisable.
    // Exemple attendu: ClientCreateDialog.razor (un seul formulaire client) avec paramètres:
    // - Title
    // - RoleLabel (préselection)
    // - OnSaved: EventCallback<ClientModel>
    try
    {
        var roleLabel = GetRoleLabel(role);

        var parameters = new DialogParameters
        {
            ["RoleLabel"] = roleLabel
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

        var dialog = await DialogService.ShowAsync<GesCPSI_Project.Components.Dialogs.ClientCreateDialog>($"Créer un client – {roleLabel}", parameters, options);
        var result = await dialog.Result;

        // ✅ sécurité null
        if (result is null || result.Canceled)
            return;

        if (!result.Canceled && result.Data is ClientModel created)
        {
            SelectClient(role, created);

            // Bonus: si on a déjà un acte brouillon, on peut sauvegarder l'association immédiatement
            if (currentActeId.HasValue || ActeId.HasValue)
            {
                await EnsureActeAsync();

                if (!currentActeId.HasValue)
                    throw new InvalidOperationException("Acte non initialisé après EnsureActeAsync().");

                await UpsertClientActeAsync(currentActeId.Value, role, created.IdClt);
                Snackbar.Add($"Client créé et assigné ({roleLabel}).", Severity.Success);
            }
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add($"Erreur dialog création client: {ex.Message}", Severity.Error);
    }
}

private void OpenCreateClientPage(ParticipantRole role)
{
    // Option 2 : page dédiée client + retour ici.
    // On passe returnUrl + role dans la query.
    // Ex: /clientPage?returnUrl=/saisirPage/3?acteId=101&role=Debiteur
    var roleKey = role.ToString(); // Debiteur/Caution/Temoin1/Temoin2
    var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);

    // Si acteId existe déjà : passe-le, sinon la page créera juste le client (liaison se fera après)
    var acte = currentActeId ?? ActeId;

    NavigationManager.NavigateTo($"/clientPage/{IdAjout}?returnUrl={returnUrl}&role={roleKey}&acteId={acte}", forceLoad: true);
}

private void OpenClientEditPage(ParticipantRole role)
{
    var ps = participants[role];
    if (ps.ClientId is null || ps.ClientId.Value <= 0)
    {
        Snackbar.Add("Aucun client à modifier pour ce rôle.", Severity.Warning);
        return;
    }

    var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);
    NavigationManager.NavigateTo($"/clientPage/{IdAjout}?clientId={ps.ClientId.Value}&returnUrl={returnUrl}&role={role}", forceLoad: true);
}

private static string GetRoleLabel(ParticipantRole role) => role switch
{
    ParticipantRole.Debiteur => "Debiteur",
    ParticipantRole.Caution => "Caution",
    ParticipantRole.Temoin1 => "Temoin1",
    ParticipantRole.Temoin2 => "Temoin2",
    _ => "Client"
};

// =================== NAVIGATION WIZARD ===================

private void OnBack()
{
    successMessage = null;
    errorMessage = null;

    if (step == WizardStep.Participants)
    {
        NavigationManager.NavigateTo("/choisirAct", true);
        return;
    }

    step = step switch
    {
        WizardStep.Cautionnement => WizardStep.Participants,
        WizardStep.Pret => WizardStep.Cautionnement,
        WizardStep.Autorisation => WizardStep.Pret,
        WizardStep.Charge => WizardStep.Autorisation,
        WizardStep.EntiteJuridique => WizardStep.Charge,
        WizardStep.Recap => WizardStep.EntiteJuridique,
        _ => step
    };

    StateHasChanged();
}

private async Task OnNext()
{
    successMessage = null;
    errorMessage = null;

    bool isValid = step switch
    {
        WizardStep.Participants => ValidateParticipants(),
        WizardStep.Cautionnement => cautionnementContext.Validate(),
        WizardStep.Pret => pretContext.Validate(),
        WizardStep.Autorisation => autorisationContext.Validate(),
        WizardStep.Charge => chargeContext.Validate(),
        WizardStep.EntiteJuridique => entiteJurContext.Validate(),
        _ => true
    };

    if (!isValid)
    {
        errorMessage = "Veuillez compléter correctement cette étape.";
        return;
    }

    try
    {
        isBusy = true;
        await SaveStepAsync();
    }
    catch (Exception ex)
    {
        errorMessage = $"Erreur sauvegarde étape : {ex.Message}";
        Snackbar.Add(errorMessage, Severity.Error);
        return;
    }
    finally
    {
        isBusy = false;
    }

    step = step switch
    {
        WizardStep.Participants => WizardStep.Cautionnement,
        WizardStep.Cautionnement => WizardStep.Pret,
        WizardStep.Pret => WizardStep.Autorisation,
        WizardStep.Autorisation => WizardStep.Charge,
        WizardStep.Charge => WizardStep.EntiteJuridique,
        WizardStep.EntiteJuridique => WizardStep.Recap,
        _ => step
    };

    await InvokeAsync(StateHasChanged);
}

private void OnReset()
{
    isBusy = true;
    successMessage = null;
    errorMessage = null;

    model = new CautionnementSaisieViewModel();
    editContext = new EditContext(model);

    cautionnementContext = new EditContext(model.Cautionnement);
    pretContext = new EditContext(model.Pret);
    autorisationContext = new EditContext(model.Autorisation);
    chargeContext = new EditContext(model.Charge);
    entiteJurContext = new EditContext(model.EntiteJuridique);

    foreach (var k in participants.Keys.ToList())
        participants[k] = new ParticipantState();

    step = WizardStep.Participants;
    currentActeId = null;

    isBusy = false;
    StateHasChanged();
}

private bool ValidateParticipants()
{
    if (participants[ParticipantRole.Debiteur].ClientId is null)
        return false;

    if (participants[ParticipantRole.Caution].ClientId is null)
        return false;

    if (showTemoins)
    {
        if (participants[ParticipantRole.Temoin1].ClientId is null)
            return false;

        if (participants[ParticipantRole.Temoin2].ClientId is null)
            return false;
    }

    return true;
}

// =================== SAVE / LOAD ===================

    private async Task EnsureActeAsync()
    {
        if (currentActeId.HasValue && currentActeId.Value > 0)
            return;

        if (ActeId.HasValue && ActeId.Value > 0)
        {
            currentActeId = ActeId.Value;
            return;
        }

        var boaId = await GetBoaBankIdAsync();
        if (!boaId.HasValue)
            throw new InvalidOperationException("La banque BOA-TOGO n'est pas configurée. Impossible de créer un acte.");

        selectedBanqueId = boaId.Value;

        // 🔥 Récupère le vrai user connecté (fini le hardcodé "userId = 1")
        var userId = await GetCurrentUserIdAsync();
        if (userId is null)
            throw new InvalidOperationException("Impossible d'identifier l'utilisateur connecté. Reconnectez-vous.");

        var nomActe = ajoutAct?.NomAct ?? "Cautionnement";

        var acte = new TypesActModel
            {
                NomTypesActe = nomActe,
                DateCreation = NowUtc(),
                DateMaj = NowUtc(),
                Statut = "Brouillon",
                StatutWorkflow = ActeStatut.Brouillon,
                IdAjout = IdAjout,
                IdUser = userId.Value,
                IdBnq = boaId.Value
            };

        var res = await TypesActService.AddAsync(acte);
        if (!res.IsSuccess || res.Data is null)
            throw new InvalidOperationException(res.ErrorMessage ?? "Création acte impossible.");

        currentActeId = res.Data.IdActe;

        // 🆕 Tracer la création dans le journal d'audit
        try
        {
            await WorkflowService.LogCreationAsync(currentActeId.Value, userId.Value);
        }
        catch (Exception ex)
        {
            // On ne casse pas le workflow si le log d'audit échoue
            // (les données métier sont déjà sauvées, c'est juste l'historique qui n'est pas tracé)
            Console.WriteLine($"[AUDIT] Erreur log création acte #{currentActeId} : {ex.Message}");
        }

        Snackbar.Add($"Brouillon créé (Acte #{currentActeId}).", Severity.Info);
    }

private async Task SaveStepAsync()
{
    await EnsureActeAsync();

    if (!currentActeId.HasValue)
        throw new InvalidOperationException("Aucun acte courant disponible après EnsureActeAsync().");

    var acteId = currentActeId.Value;

    var boaId = await GetBoaBankIdAsync();
    if (!boaId.HasValue)
            throw new InvalidOperationException("La banque BOA-TOGO n'est pas configurée.");

    selectedBanqueId = boaId.Value;

    // Toujours mettre à jour la banque si l'utilisateur change
    var acte = await TypesActService.GetByIdAsync(acteId);
    if (acte is not null)
    {
        acte.IdBnq = boaId.Value;
        acte.DateMaj = NowUtc();

        // await TypesActService.UpdateAsync(acte);
        var updateActe = await TypesActService.UpdateAsync(acte);
        if (!updateActe.IsSuccess)
            throw new InvalidOperationException(updateActe.ErrorMessage ?? "Erreur mise à jour acte.");
    }

    switch (step)
    {
        case WizardStep.Participants:
            await SaveParticipantsAsync(acteId);
            break;

        case WizardStep.Cautionnement:
            await UpsertCautionnementAsync(acteId);
            break;

        case WizardStep.Pret:
            await UpsertPretAsync(acteId);
            break;

        case WizardStep.Autorisation:
            await UpsertAutorisationAsync(acteId);
            break;

        case WizardStep.Charge:
            await UpsertChargeAsync(acteId);
            break;

        case WizardStep.EntiteJuridique:
            await UpsertEntiteJurAsync(acteId);
            // avant recap, on s'assure d'avoir le snapshot affichable
            await EnsureParticipantSnapshotsAsync();
            break;
    }
}

private async Task SaveParticipantsAsync(int acteId)
{
    var debiteurId = participants[ParticipantRole.Debiteur].ClientId
        ?? throw new InvalidOperationException("Le débiteur est obligatoire.");

    var cautionId = participants[ParticipantRole.Caution].ClientId
        ?? throw new InvalidOperationException("La caution est obligatoire.");

    await UpsertClientActeAsync(acteId, ParticipantRole.Debiteur, debiteurId);
    await UpsertClientActeAsync(acteId, ParticipantRole.Caution, cautionId);

    if (showTemoins)
    {
        var temoin1Id = participants[ParticipantRole.Temoin1].ClientId
            ?? throw new InvalidOperationException("Le témoin 1 est obligatoire.");

        var temoin2Id = participants[ParticipantRole.Temoin2].ClientId
            ?? throw new InvalidOperationException("Le témoin 2 est obligatoire.");

        await UpsertClientActeAsync(acteId, ParticipantRole.Temoin1, temoin1Id);
        await UpsertClientActeAsync(acteId, ParticipantRole.Temoin2, temoin2Id);
    }

    await EnsureParticipantSnapshotsAsync();
    Snackbar.Add("Participants enregistrés.", Severity.Success);
}




private Dictionary<string, int>? _roleCache;

private async Task<int> GetRoleIdAsync(ParticipantRole role)
{
    _roleCache ??= new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

    var label = GetRoleLabel(role);
    if (_roleCache.TryGetValue(label, out var cached))
        return cached;

    var roles = await RolesClientActService.GetAllAsync() ?? new List<RolesClientActModel>();
    var r = roles.FirstOrDefault(x => string.Equals(x.Libelle?.Trim(), label, StringComparison.OrdinalIgnoreCase));

    if (r is null)
        throw new InvalidOperationException($"Rôle introuvable en base: {label}");

    _roleCache[label] = r.IdRole;
    return r.IdRole;
}

private async Task UpsertClientActeAsync(int acteId, ParticipantRole role, int clientId)
{
    var roleId = await GetRoleIdAsync(role);

    var all = await ClientActService.GetAllAsync() ?? new List<ClientActModel>();
    var existing = all.FirstOrDefault(x => x.IdActe == acteId && x.IdRole == roleId);

    if (existing is null)
    {
        var ca = new ClientActModel
        {
            IdActe = acteId,
            IdClt = clientId,
            IdRole = roleId,
            DescriptionRole = GetRoleLabel(role)
        };

        var res = await ClientActService.AddAsync(ca);
        if (!res.IsSuccess)
            throw new InvalidOperationException(res.ErrorMessage ?? "Erreur ajout ClientAct.");
        return;
    }

    if (existing.IdClt == clientId &&
        string.Equals(existing.DescriptionRole, GetRoleLabel(role), StringComparison.OrdinalIgnoreCase))
    {
        return;
    }

    var updated = new ClientActModel
    {
        IdCltActe = existing.IdCltActe,
        IdActe = existing.IdActe,
        IdRole = existing.IdRole,
        IdClt = clientId,
        DescriptionRole = GetRoleLabel(role)
    };

    var upd = await ClientActService.UpdateAsync(updated);
    if (!upd.IsSuccess)
        throw new InvalidOperationException(upd.ErrorMessage ?? "Erreur update ClientAct.");
}



private async Task EnsureParticipantSnapshotsAsync()
{
    foreach (var role in participants.Keys)
    {
        var ps = participants[role];
        if (ps.ClientId.HasValue && ps.Selected is null)
        {
            var c = await ClientService.GetByIdAsync(ps.ClientId.Value);
            ps.Selected = c;
        }
    }
}

// ======== UPSERT ENTITES JURIDIQUES (1-1 par acte) ========

static DateTime ToUtc(DateTime dt)
{
    if (dt.Kind == DateTimeKind.Utc) return dt;
    if (dt.Kind == DateTimeKind.Local) return dt.ToUniversalTime();
    return DateTime.SpecifyKind(dt, DateTimeKind.Local).ToUniversalTime();
}

private async Task UpsertCautionnementAsync(int acteId)
{
    var nomActe = ajoutAct?.NomAct ?? "Cautionnement";

    var all = await CautionnementService.GetAllAsync() ?? new List<CautionnementModel>();
    var existing = all.FirstOrDefault(x => x.IdActe == acteId);

    var entity = new CautionnementModel
    {
        IdCautionnement = existing?.IdCautionnement ?? 0,
        IdActe = acteId,
        NomTypesActe = nomActe,

        NumeroCautionmt = model.Cautionnement.NumeroCautionmt ?? string.Empty,
        MontantCautionne = model.Cautionnement.MontantCautionne,
        MontantLettreCautionmt = model.Cautionnement.MontantLettreCautionmt ?? string.Empty,
        DateSignatureCautionmt = ToUtc(model.Cautionnement.DateSignatureCautionmt),
        DateEffetCautionmt = ToUtc(model.Cautionnement.DateEffetCautionmt),
        DateExpirationCautionmt = ToUtc(model.Cautionnement.DateExpirationCautionmt),
        LieuSignatureCautionmt = model.Cautionnement.LieuSignatureCautionmt ?? string.Empty,
        EtatCautionmt = model.Cautionnement.EtatCautionmt ?? string.Empty,
        ConditionsRevocationCautionmt = model.Cautionnement.ConditionsRevocationCautionmt ?? string.Empty,
        ObligationsBanque = model.Cautionnement.ObligationsBanque ?? string.Empty,
        ObligationsCaution = model.Cautionnement.ObligationsCaution ?? string.Empty,
        ClauseSubrogation = model.Cautionnement.ClauseSubrogation ?? string.Empty,
        ClauseNonNovation = model.Cautionnement.ClauseNonNovation ?? string.Empty,
        ElectionDomicile = model.Cautionnement.ElectionDomicile ?? string.Empty,
        ReglementDifferend = model.Cautionnement.ReglementDifferend ?? string.Empty
    };

    if (existing is null)
    {
        var res = await CautionnementService.AddAsync(entity);
        if (!res.IsSuccess) throw new InvalidOperationException(res.ErrorMessage ?? "Erreur ajout cautionnement.");
    }
    else
    {
        var res = await CautionnementService.UpdateAsync(entity);
        if (!res.IsSuccess) throw new InvalidOperationException(res.ErrorMessage ?? "Erreur update cautionnement.");
    }
}

