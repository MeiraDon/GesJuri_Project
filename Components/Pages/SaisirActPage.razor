// =================== LOAD EXISTING ACTE ===================

private async Task LoadExistingActe(int acteId)
{
    try
    {
        isBusy = true;

        var acte = await TypesActService.GetByIdAsync(acteId);
        if (acte is null) return;

        currentActeId = acte.IdActe;
        selectedBanqueId = acte.IdBnq ?? boaBank?.IdBnq;

        await LoadParticipantsForActe(acteId);
        await LoadActeDetails(acteId);

        await EnsureParticipantSnapshotsAsync();
        StateHasChanged();
    }
    catch (Exception ex)
    {
        errorMessage = $"Erreur lors du chargement de l'acte : {ex.Message}";
    }
    finally
    {
        isBusy = false;
    }
}

private async Task LoadParticipantsForActe(int acteId)
{
    var clientActes = await ClientActService.GetAllAsync() ?? new List<ClientActModel>();
    var roles = await RolesClientActService.GetAllAsync() ?? new List<RolesClientActModel>();

    var filtered = clientActes.Where(ca => ca.IdActe == acteId).ToList();

    foreach (var ca in filtered)
    {
        var role = roles.FirstOrDefault(r => r.IdRole == ca.IdRole)?.Libelle?.Trim() ?? "";
        var pr = role.ToLowerInvariant();

        if (pr is "débiteur" or "debiteur")
            participants[ParticipantRole.Debiteur].ClientId = ca.IdClt;
        else if (pr is "caution")
            participants[ParticipantRole.Caution].ClientId = ca.IdClt;
        else if (pr is "témoin1" or "temoin1" or "temoins1")
            participants[ParticipantRole.Temoin1].ClientId = ca.IdClt;
        else if (pr is "témoin2" or "temoin2" or "temoins2")
            participants[ParticipantRole.Temoin2].ClientId = ca.IdClt;
    }
}

private async Task LoadActeDetails(int acteId)
{
    // Cautionnement
    var cautionnements = await CautionnementService.GetAllAsync() ?? new List<CautionnementModel>();
    var c = cautionnements.FirstOrDefault(x => x.IdActe == acteId);

    model.Cautionnement = c is null ? new CautionnementViewModel() : new CautionnementViewModel
    {
        NumeroCautionmt = c.NumeroCautionmt,
        MontantCautionne = c.MontantCautionne,
        MontantLettreCautionmt = c.MontantLettreCautionmt,
        DateSignatureCautionmt = ToUtc(c.DateSignatureCautionmt),
        DateEffetCautionmt = ToUtc(c.DateEffetCautionmt),
        DateExpirationCautionmt = ToUtc(c.DateExpirationCautionmt),
        LieuSignatureCautionmt = c.LieuSignatureCautionmt,
        EtatCautionmt = c.EtatCautionmt,
        ConditionsRevocationCautionmt = c.ConditionsRevocationCautionmt,
        ObligationsBanque = c.ObligationsBanque,
        ObligationsCaution = c.ObligationsCaution,
        ClauseSubrogation = c.ClauseSubrogation,
        ClauseNonNovation = c.ClauseNonNovation,
        ElectionDomicile = c.ElectionDomicile,
        ReglementDifferend = c.ReglementDifferend
    };

    // Prêt
    var prets = await PretService.GetAllAsync() ?? new List<PretModel>();
    var p = prets.FirstOrDefault(x => x.IdActe == acteId);

    model.Pret = p is null ? new PretViewModel() : new PretViewModel
    {
        ReferenceConvention = p.ReferenceConvention,
        MontantConcours = p.MontantConcours,
        Taux = p.Taux,
        MontantLettrePret = p.MontantLettrePret,
        Accessoires = p.Accessoires,
        ObjetPret = p.ObjetPret,
        DateSignaturePret = ToUtc(p.DateSignaturePret),
        DureMoisPret = p.DureMoisPret,
        DateDebutRemboursemnt = ToUtc(p.DateDebutRemboursemnt),
        DatePremiereEcheance = ToUtc(p.DatePremiereEcheance),
        MontantPremiereEcheance = p.MontantPremiereEcheance,
        DateDerniereEcheance = ToUtc(p.DateDerniereEcheance),
        MontantDerniereEcheance = p.MontantDerniereEcheance,
        EtatPret = p.EtatPret
    };

    // Autorisation
    var autos = await AutorisationService.GetAllAsync() ?? new List<AutorisationModel>();
    var a = autos.FirstOrDefault(x => x.IdActe == acteId);
    model.Autorisation = a is null ? new AutorisationViewModel() : new AutorisationViewModel
    {
        NumeroAutorisation = a.NumeroAutorisation,
        DateAutorisation = ToUtc(a.DateAutorisation),
        LieuAutorisation = a.LieuAutorisation,
        MontantMaxAutorise = a.MontantMaxAutorise,
        ConditionsAutorisation = a.ConditionsAutorisation
    };

    // Charge
    var charges = await ChargeService.GetAllAsync() ?? new List<ChargeModel>();
    var ch = charges.FirstOrDefault(x => x.IdActe == acteId);
    model.Charge = ch is null ? new ChargeViewModel() : new ChargeViewModel
    {
        TypeCharge = ch.TypeCharge,
        MontantCharge = ch.MontantCharge,
        DateCharge = ToUtc(ch.DateCharge),
        PayePar = ch.PayePar,
        StatutCharge = ch.StatutCharge
    };

    // Entité juridique
    var ents = await EntiteJurService.GetAllAsync() ?? new List<EntiteJurModel>();
    var e = ents.FirstOrDefault(x => x.IdActe == acteId);
    model.EntiteJuridique = e is null ? new EntiteJurViewModel() : new EntiteJurViewModel
    {
        DateActeJuridique = ToUtc(e.DateActeJuridique),
        Reference = e.Reference,
        NomHuissier = e.NomHuissier,
        VilleHuissier = e.VilleHuissier,
        NumeroDossier = e.NumeroDossier,
        Responsable = e.Responsable,
        FonctionResponsable = e.FonctionResponsable,
        NomDossier = e.NomDossier

    };

    // Refresh EditContexts (car on a remplacé des sous-objets)
    cautionnementContext = new EditContext(model.Cautionnement);
    pretContext = new EditContext(model.Pret);
    autorisationContext = new EditContext(model.Autorisation);
    chargeContext = new EditContext(model.Charge);
    entiteJurContext = new EditContext(model.EntiteJuridique);
}

// =================== SUBMIT FINAL ===================

private async Task OnSubmit()
{
    try
    {
        isBusy = true;
        errorMessage = null;
        successMessage = null;

        if (!ValidateParticipants()
            || !cautionnementContext.Validate()
            || !pretContext.Validate()
            || !autorisationContext.Validate()
            || !chargeContext.Validate()
            || !entiteJurContext.Validate())
        {
            errorMessage = "Veuillez corriger toutes les erreurs de validation avant de soumettre.";
            return;
        }

        await EnsureActeAsync();

        if (!currentActeId.HasValue)
            throw new InvalidOperationException("Aucun acte courant disponible après EnsureActeAsync().");

        var acteId = currentActeId.Value;

        await SaveParticipantsAsync(acteId);
        await UpsertCautionnementAsync(acteId);
        await UpsertPretAsync(acteId);
        await UpsertAutorisationAsync(acteId);
        await UpsertChargeAsync(acteId);
        await UpsertEntiteJurAsync(acteId);

        var acte = await TypesActService.GetByIdAsync(acteId);
        if (acte is not null)
        {
            acte.Statut = "EnAttenteEnvoi";
            acte.DateMaj = NowUtc();

            // await TypesActService.UpdateAsync(acte);
            var upd = await TypesActService.UpdateAsync(acte);
            if (!upd.IsSuccess)
                throw new InvalidOperationException(upd.ErrorMessage ?? "Erreur update acte.");
        }

        successMessage = "L'acte a été validé avec succès et est maintenant en attente d'envoi au responsable.";
        await Task.Delay(1200);

        // ✅ Retour vers listAct + demande refresh
        var back = string.IsNullOrWhiteSpace(ReturnUrl) ? "/listAct" : ReturnUrl;
        var sep = back.Contains('?') ? "&" : "?";
        NavigationManager.NavigateTo($"{back}{sep}refresh=1", forceLoad: true);
        return;
    }
    catch (Exception ex)
    {
        errorMessage = $"Erreur lors de l'enregistrement : {ex.Message}";
        successMessage = null;
    }
    finally
    {
        isBusy = false;
        StateHasChanged();
    }
    
}
}
