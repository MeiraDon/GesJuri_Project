@page "/saisirPage/{IdAjout:int}"
@rendermode InteractiveServer

<PageTitle>Saisie</PageTitle>

@using MudBlazor
@using GesCPSI_Project.Models
@using GesCPSI_Project.Interfaces
@using GesCPSI_Project.Services
@using Microsoft.AspNetCore.Components.Forms
@using GesCPSI_Project.Components.Shared
@using GesCPSI_Project.ViewModels
@using Microsoft.AspNetCore.Components.Authorization


@inject IClientAct ClientActService
@inject ITypesAct TypesActService
@inject IAjoutAct AjoutActService
@inject IRolesClientAct RolesClientActService
@inject IClient ClientService
@inject ICautionnement CautionnementService
@inject IPret PretService
@inject ICharge ChargeService
@inject IAutorisation AutorisationService
@inject IEntiteJur EntiteJurService
@inject IUser UserService
@inject IBanque BanqueService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IActeWorkflow WorkflowService
@inject AuthenticationStateProvider AuthStateProvider

<div class="container py-4" lang="fr">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
                <div>
                    <h1 class="h4 mb-1">Saisie – Acte de cautionnement</h1>
                    <div class="text-muted">Renseignez les informations étape par étape.</div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge text-bg-primary">Étape @((int)step + 1)/7</span>
                    <span class="text-muted small">@GetStepLabel(step)</span>
                </div>
            </div>

            <MudPaper Class="pa-3 mb-3" Elevation="0" Style="border:1px dashed rgba(0,51,102,.2); border-radius:10px;">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <MudText Typo="Typo.subtitle2" Class="mb-0">
                        Banque liée à l’acte
                    </MudText>

                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                        @GetBanqueActeLabel()
                    </MudChip>
                </div>

                @if (boaBank is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        Cette application crée uniquement des actes pour la banque BOA-TOGO.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">
                        La banque BOA-TOGO n’est pas configurée dans le référentiel.
                    </MudText>
                }
            </MudPaper>

            <div class="card shadow-sm">
                <div class="card-body">

                    <EditForm EditContext="@CurrentContext" OnSubmit="@(_ => Task.CompletedTask)">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <div class="progress" style="height: 10px;" aria-label="Progression">
                                <div class="progress-bar" role="progressbar"
                                     style="@($"width: {GetProgressPercent()}%")"
                                     aria-valuenow="@GetProgressPercent()" aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                        </div>

                        @* =================== PARTICIPANTS (NOUVEAU) =================== *@
                        @if (step == WizardStep.Participants)
                        {
                            <ClientHeader Title="Participants" Subtitle="Choisissez ou créez les personnes (Débiteur / Caution / Témoins)"
                                          IconCss="bi bi-people big-bold-icon" />

                            <div class="row g-3">
                                <div class="col-12 col-lg-6">
                                    @RenderParticipantCard(ParticipantRole.Debiteur, "Débiteur", "bi bi-person")
                                </div>
                                <div class="col-12 col-lg-6">
                                    @RenderParticipantCard(ParticipantRole.Caution, "Caution", "bi bi-person-lock")
                                </div>
                                @if (showTemoins)
                                {
                                    <div class="col-12 col-lg-6">
                                        @RenderParticipantCard(ParticipantRole.Temoin1, "Témoin 1", "bi bi-person-check")
                                    </div>

                                    <div class="col-12 col-lg-6">
                                        @RenderParticipantCard(ParticipantRole.Temoin2, "Témoin 2", "bi bi-person-check")
                                    </div>
                                }
                            </div>

                            <div class="alert alert-info mt-3 mb-0">
                                <i class="bi bi-lightbulb me-2"></i>
                                Astuce : recherchez par <b>nom</b>, <b>téléphone</b> ou <b>pièce</b> (Type + Numéro).
                            </div>
                        }

                        @* =================== CAUTIONNEMENT =================== *@
                        @if (step == WizardStep.Cautionnement)
                        {
                            <ClientHeader Title="Cautionnement" Subtitle="Informations juridiques de l'acte de cautionnement"
                                          IconCss="bi bi-file-earmark-text big-bold-icon" />
                            <CascadingValue Value="cautionnementContext" IsFixed="true">
                                <GesCPSI_Project.Components.Forms.CautionnementForm Cautionnement="@model.Cautionnement" />
                            </CascadingValue>
                        }

                        @* =================== PRET =================== *@
                        @if (step == WizardStep.Pret)
                        {
                            <ClientHeader Title="Prêt" Subtitle="Informations sur le prêt bancaire"
                                          IconCss="bi bi-cash-coin big-bold-icon" />
                            <CascadingValue Value="pretContext" IsFixed="true">
                                <GesCPSI_Project.Components.Forms.PretForm Pret="@model.Pret" />
                            </CascadingValue>
                        }

                        @* =================== AUTORISATION =================== *@
                        @if (step == WizardStep.Autorisation)
                        {
                            <ClientHeader Title="Autorisation de débit" Subtitle="Autorisation de prélèvement bancaire"
                                          IconCss="bi bi-credit-card big-bold-icon" />
                            <CascadingValue Value="autorisationContext" IsFixed="true">
                                <GesCPSI_Project.Components.Forms.AutorisationForm Autorisation="@model.Autorisation" />
                            </CascadingValue>
                        }

                        @* =================== CHARGE =================== *@
                        @if (step == WizardStep.Charge)
                        {
                            <ClientHeader Title="Charges" Subtitle="Frais et taxes associés à l'acte"
                                          IconCss="bi bi-receipt big-bold-icon" />
                            <CascadingValue Value="chargeContext" IsFixed="true">
                                <GesCPSI_Project.Components.Forms.ChargeForm Charge="@model.Charge" />
                            </CascadingValue>
                        }

                        @* =================== ENTITE JURIDIQUE =================== *@
                        @if (step == WizardStep.EntiteJuridique)
                        {
                            <ClientHeader Title="Entité Juridique" Subtitle="Informations sur l'officier public"
                                          IconCss="bi bi-building big-bold-icon" />
                            <CascadingValue Value="entiteJurContext" IsFixed="true">
                                <GesCPSI_Project.Components.Forms.EntiteJurForm EntiteJuridique="@model.EntiteJuridique" />
                            </CascadingValue>
                        }

                        @* =================== RECAP =================== *@
                        @if (step == WizardStep.Recap)
                        {
                            <ClientHeader Title="Récapitulatif" Subtitle="Vérifiez avant de valider"
                                          IconCss="bi bi-clipboard-check big-bold-icon" />

                            <ValidationSummary />

                            <div class="row g-3">

                                <div class="col-12">
                                    <div class="border rounded p-3">
                                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                            <div class="fw-semibold">
                                                <i class="bi bi-people me-2"></i>Participants
                                            </div>
                                            <span class="badge text-bg-light">
                                                Acte : @(currentActeId ?? ActeId ?? 0)
                                            </span>
                                        </div>

                                        <div class="row g-2 mt-2">
                                            <div class="col-12 col-lg-6">
                                                @RenderParticipantRecap("Débiteur", participants[ParticipantRole.Debiteur])
                                            </div>
                                            <div class="col-12 col-lg-6">
                                                @RenderParticipantRecap("Caution", participants[ParticipantRole.Caution])
                                            </div>
                                            @if (showTemoins)
                                            {
                                                <div class="col-12 col-lg-6">
                                                    @RenderParticipantRecap("Témoin 1", participants[ParticipantRole.Temoin1])
                                                </div>

                                                <div class="col-12 col-lg-6">
                                                    @RenderParticipantRecap("Témoin 2", participants[ParticipantRole.Temoin2])
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- =================== CAUTIONNEMENT =================== -->
                                <div class="col-12">
                                    <div class="border rounded p-3">
                                        <div class="fw-semibold mb-2">Cautionnement</div>
                                        <dl class="row mb-0">
                                            <dt class="col-4 text-muted">N° cautionnement</dt>
                                            <dd class="col-8 mb-1">@model.Cautionnement.NumeroCautionmt</dd>
                                            <dt class="col-4 text-muted">Montant</dt>
                                            <dd class="col-8 mb-1">@model.Cautionnement.MontantCautionne.ToString("N0") FCFA</dd>
                                            <dt class="col-4 text-muted">Date signature</dt>
                                            <dd class="col-8 mb-1">@model.Cautionnement.DateSignatureCautionmt.ToString("dd/MM/yyyy")</dd>
                                            <dt class="col-4 text-muted">Date expiration</dt>
                                            <dd class="col-8 mb-0">@model.Cautionnement.DateExpirationCautionmt.ToString("dd/MM/yyyy")</dd>
                                        </dl>
                                    </div>
                                </div>

                                <!-- =================== PRET =================== -->
                                <div class="col-12">
                                    <div class="border rounded p-3">
                                        <div class="fw-semibold mb-2">Prêt</div>
                                        <dl class="row mb-0">
                                            <dt class="col-4 text-muted">Référence</dt>
                                            <dd class="col-8 mb-1">@model.Pret.ReferenceConvention</dd>

                                            <dt class="col-4 text-muted">Montant</dt>
                                            <dd class="col-8 mb-1">@model.Pret.MontantConcours.ToString("N0") FCFA</dd>

                                            <dt class="col-4 text-muted">Durée</dt>
                                            <dd class="col-8 mb-1">@model.Pret.DureMoisPret mois</dd>

                                            <dt class="col-4 text-muted">Date signature</dt>
                                            <dd class="col-8 mb-0">@model.Pret.DateSignaturePret.ToString("dd/MM/yyyy")</dd>
                                        </dl>
                                    </div>
                                </div>

                                <!-- =================== AUTORISATION =================== -->
                                <div class="col-12">
                                    <div class="border rounded p-3">
                                        <div class="fw-semibold mb-2">Autorisation de débit</div>
                                        <dl class="row mb-0">
                                            <dt class="col-4 text-muted">N° autorisation</dt>
                                            <dd class="col-8 mb-1">@model.Autorisation.NumeroAutorisation</dd>

                                            <dt class="col-4 text-muted">Date</dt>
                                            <dd class="col-8 mb-1">@model.Autorisation.DateAutorisation.ToString("dd/MM/yyyy")</dd>

                                            <dt class="col-4 text-muted">Lieu</dt>
                                            <dd class="col-8 mb-1">@model.Autorisation.LieuAutorisation</dd>

                                            <dt class="col-4 text-muted">Montant max autorisé</dt>
                                            <dd class="col-8 mb-1">@model.Autorisation.MontantMaxAutorise.ToString("N0") FCFA</dd>

                                            <dt class="col-4 text-muted">Conditions</dt>
                                            <dd class="col-8 mb-0">@model.Autorisation.ConditionsAutorisation</dd>
                                        </dl>
                                    </div>
                                </div>

                                <!-- =================== CHARGES =================== -->
                                <div class="col-12">
                                    <div class="border rounded p-3">
                                        <div class="fw-semibold mb-2">Charges</div>
                                        <dl class="row mb-0">
                                            <dt class="col-4 text-muted">Type</dt>
                                            <dd class="col-8 mb-1">@model.Charge.TypeCharge</dd>

                                            <dt class="col-4 text-muted">Montant</dt>
                                            <dd class="col-8 mb-1">@model.Charge.MontantCharge.ToString("N0") FCFA</dd>

                                            <dt class="col-4 text-muted">Date</dt>
                                            <dd class="col-8 mb-1">@model.Charge.DateCharge.ToString("dd/MM/yyyy")</dd>

                                            <dt class="col-4 text-muted">Payé par</dt>
                                            <dd class="col-8 mb-1">@model.Charge.PayePar</dd>

                                            <dt class="col-4 text-muted">Statut</dt>
                                            <dd class="col-8 mb-0">@model.Charge.StatutCharge</dd>
                                        </dl>
                                    </div>
                                </div>

                                <!-- =================== ENTITE JURIDIQUE =================== -->
                                <div class="col-12">
                                    <div class="border rounded p-3">
                                        <div class="fw-semibold mb-2">Entité juridique</div>
                                        <dl class="row mb-0">
                                            <dt class="col-4 text-muted">Date acte</dt>
                                            <dd class="col-8 mb-1">@model.EntiteJuridique.DateActeJuridique.ToString("dd/MM/yyyy")</dd>

                                            <dt class="col-4 text-muted">Référence</dt>
                                            <dd class="col-8 mb-1">@model.EntiteJuridique.Reference</dd>

                                            <dt class="col-4 text-muted">Nom huissier</dt>
                                            <dd class="col-8 mb-1">@model.EntiteJuridique.NomHuissier</dd>

                                            <dt class="col-4 text-muted">Ville huissier</dt>
                                            <dd class="col-8 mb-1">@model.EntiteJuridique.VilleHuissier</dd>

                                            <dt class="col-4 text-muted">N° dossier</dt>
                                            <dd class="col-8 mb-1">@model.EntiteJuridique.NumeroDossier</dd>

                                            <dt class="col-4 text-muted">Responsable</dt>
                                            <dd class="col-8 mb-1">@model.EntiteJuridique.Responsable</dd>

                                            <dt class="col-4 text-muted">Fonction</dt>
                                            <dd class="col-8 mb-0">@model.EntiteJuridique.FonctionResponsable</dd>
                                        </dl>
                                    </div>
                                </div>

                            </div>


                            @if (!string.IsNullOrWhiteSpace(successMessage))
                            {
                                <div class="alert alert-success mt-3 mb-0" role="alert">
                                    <i class="bi bi-check-circle me-2"></i>@successMessage
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(errorMessage))
                            {
                                <div class="alert alert-danger mt-3 mb-0" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                                </div>
                            }
                        }

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-4">
                            <button type="button" class="btn btn-outline-secondary"
                                    @onclick="OnBack" disabled="@(step == WizardStep.Participants)"> 
                                <i class="bi bi-arrow-left me-2"></i>Précédent
                            </button>

                            <div class="d-flex align-items-center gap-2">
                                <button type="button" class="btn btn-outline-danger"
                                        @onclick="OnReset" disabled="@isBusy">
                                    <i class="bi bi-arrow-counterclockwise me-2"></i>Réinitialiser
                                </button>

                                @if (step != WizardStep.Recap)
                                {
                                    <button type="button" class="btn btn-primary" disabled="@isBusy" @onclick="OnNext">
                                        Suivant<i class="bi bi-arrow-right ms-2"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-success"
                                            @onclick="OnSubmit" disabled="@isBusy">
                                        <i class="bi bi-check me-2"></i>Valider
                                    </button>
                                }
                            </div>
                        </div>
                    </EditForm>

                </div>
            </div>

            <div class="text-muted small mt-3">
                Astuce : vous pouvez revenir en arrière à tout moment pour corriger les informations.
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public int IdAjout { get; set; }

    private AjoutActModel? acte;
    private bool showTemoins = true;


    [Parameter]
    [SupplyParameterFromQuery(Name = "acteId")]
    public int? ActeId { get; set; }

    private CautionnementSaisieViewModel model = new();

    private bool isBusy;
    private string? successMessage;
    private string? errorMessage;
    private AjoutActModel? ajoutAct;

    private int? currentActeId;

    private List<BanqueModel> banques = new();
    private int? selectedBanqueId;
    private BanqueModel? boaBank;

    [Parameter, SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private static DateTime NowUtc() => DateTime.UtcNow;


    private async Task<int?> GetCurrentUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var nameIdentifier = authState.User.Claims
        .FirstOrDefault(c => c.Type.Contains("nameidentifier"))?.Value;

        return int.TryParse(nameIdentifier, out var id) ? id : null;
    }
    

    // ======== PARTICIPANTS (IDs ONLY) ========
    private enum ParticipantRole { Debiteur, Caution, Temoin1, Temoin2 }

    private ParticipantRole? ParseRole(string? role)
    {
        if (string.IsNullOrWhiteSpace(role)) return null;

        var r = role.Trim().ToLowerInvariant();
        return r switch
        {
            "debiteur" or "débiteur" => ParticipantRole.Debiteur,
            "caution" => ParticipantRole.Caution,
            "temoin1" or "témoin1" or "témoin 1" or "temoin 1" => ParticipantRole.Temoin1,
            "temoin2" or "témoin2" or "témoin 2" or "temoin 2" => ParticipantRole.Temoin2,
            _ => null
        };
    }

    private sealed class ParticipantState
    {
        public int? ClientId { get; set; }
        public string Search { get; set; } = "";
        public bool IsSearching { get; set; }
        public List<ClientModel> Results { get; set; } = new();
        public ClientModel? Selected { get; set; }
        public string? InfoMessage { get; set; }
    }

    private readonly Dictionary<ParticipantRole, ParticipantState> participants = new()
    {
        [ParticipantRole.Debiteur] = new ParticipantState(),
        [ParticipantRole.Caution] = new ParticipantState(),
        [ParticipantRole.Temoin1] = new ParticipantState(),
        [ParticipantRole.Temoin2] = new ParticipantState(),
    };

    // ======== EditContexts (on garde ton style) ========
    private EditContext editContext = default!;
    private EditContext cautionnementContext = default!;
    private EditContext pretContext = default!;
    private EditContext autorisationContext = default!;
    private EditContext chargeContext = default!;
    private EditContext entiteJurContext = default!;

    private WizardStep step = WizardStep.Participants;

    private enum WizardStep
    {
        Participants = 0,
        Cautionnement = 1,
        Pret = 2,
        Autorisation = 3,
        Charge = 4,
        EntiteJuridique = 5,
        Recap = 6
    }

    [Parameter, SupplyParameterFromQuery(Name = "clientId")]
    public int? ReturnClientId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "role")]
    public string? ReturnRole { get; set; }


    private void ClearReturnQueryFromUrl()
    {
        // On reconstruit une URL sans clientId/role
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);

        // garde acteId si présent (édition), supprime role/clientId
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        query.Remove("clientId");
        query.Remove("role");

        var baseUrl = $"{uri.Scheme}://{uri.Host}{(uri.IsDefaultPort ? "" : ":" + uri.Port)}{uri.AbsolutePath}";
        var newQuery = query.ToString();

        var cleanUrl = string.IsNullOrWhiteSpace(newQuery) ? baseUrl : $"{baseUrl}?{newQuery}";
        NavigationManager.NavigateTo(cleanUrl, replace: true);
    }


    private async Task ApplyReturnClientAsync()
    {
        // Si on ne vient pas de ClientPage => rien
        if (!ReturnClientId.HasValue || ReturnClientId.Value <= 0)
            return;

        var parsedRole = ParseRole(ReturnRole);
        if (parsedRole is null)
            return;

        try
        {
            var client = await ClientService.GetByIdAsync(ReturnClientId.Value);
            if (client is null)
            {
                Snackbar.Add("Client introuvable au retour.", Severity.Warning);
                return;
            }

            // Auto-remplir la carte
            SelectClient(parsedRole.Value, client);

            // (Optionnel) si acte déjà créé, on persiste tout de suite la liaison ClientAct
            if (currentActeId.HasValue || ActeId.HasValue)
            {
                await EnsureActeAsync();

                if (!currentActeId.HasValue)
                    throw new InvalidOperationException("Acte non initialisé après EnsureActeAsync().");

                await UpsertClientActeAsync(currentActeId.Value, parsedRole.Value, client.IdClt);
            }

            // Nettoyage de l’URL: enlever clientId/role pour éviter re-trigger au refresh
            ClearReturnQueryFromUrl();

            Snackbar.Add($"Client assigné automatiquement au rôle {GetRoleLabel(parsedRole.Value)}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur auto-assignation: {ex.Message}", Severity.Error);
        }
    }

    private string GetBanqueActeLabel()
    {
        if (boaBank is not null)
            return $"{boaBank.NomRaisonSocialBnq} ({boaBank.SigleBnq})";

        var banque = banques.FirstOrDefault(b => b.IdBnq == selectedBanqueId);
        if (banque is not null)
            return $"{banque.NomRaisonSocialBnq} ({banque.SigleBnq})";

        return "BOA-TOGO non configurée";
    }

    private async Task<int?> GetBoaBankIdAsync()
    {
        if (boaBank is not null)
            return boaBank.IdBnq;

        banques = await BanqueService.GetAllAsync() ?? new List<BanqueModel>();

        boaBank = banques.FirstOrDefault(b =>
            string.Equals(b.SigleBnq?.Trim(), "BOA-TOGO", StringComparison.OrdinalIgnoreCase) ||
        (b.NomRaisonSocialBnq?.Contains("BOA-TOGO", StringComparison.OrdinalIgnoreCase) ?? false)
        );

        return boaBank?.IdBnq;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            editContext = new EditContext(model);

            cautionnementContext = new EditContext(model.Cautionnement);
            pretContext = new EditContext(model.Pret);
            autorisationContext = new EditContext(model.Autorisation);
            chargeContext = new EditContext(model.Charge);
            entiteJurContext = new EditContext(model.EntiteJuridique);

            acte = await AjoutActService.GetByIdAsync(IdAjout);
            if (acte is null)
                throw new InvalidOperationException($"Type d'acte introuvable pour IdAjout={IdAjout}.");

            showTemoins = !string.Equals(acte.CategorieClient, "Personne Morale", StringComparison.OrdinalIgnoreCase);


            banques = await BanqueService.GetAllAsync() ?? new List<BanqueModel>();

            boaBank = banques.FirstOrDefault(b =>
                string.Equals(b.SigleBnq?.Trim(), "BOA-TOGO", StringComparison.OrdinalIgnoreCase) ||
            (b.NomRaisonSocialBnq?.Contains("BOA-TOGO", StringComparison.OrdinalIgnoreCase) ?? false)
            );

            if (boaBank is null)
            {
                throw new InvalidOperationException("La banque BOA-TOGO est introuvable. Veuillez d’abord enregistrer BOA-TOGO dans /banque.");
            }

            selectedBanqueId = boaBank.IdBnq;

            if (IdAjout > 0)
                ajoutAct = await AjoutActService.GetByIdAsync(IdAjout);

            if (ActeId.HasValue)
                await LoadExistingActe(ActeId.Value);
            // ===== 5. 🔥 NOUVEAU : auto-assignation après retour ClientPage =====
            await ApplyReturnClientAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur init page: {ex.Message}";
            Snackbar.Add(errorMessage, Severity.Error);
        }
    }

    private EditContext CurrentContext => step switch
    {
        WizardStep.Participants => editContext, // Participants = validation custom
        WizardStep.Cautionnement => cautionnementContext,
        WizardStep.Pret => pretContext,
        WizardStep.Autorisation => autorisationContext,
        WizardStep.Charge => chargeContext,
        WizardStep.EntiteJuridique => entiteJurContext,
        WizardStep.Recap => editContext,
        _ => editContext
    };

    private int GetProgressPercent()
    {
        var p = ((int)step + 1) / 7.0;
        return (int)Math.Round(p * 100);
    }

    private string GetStepLabel(WizardStep s) => s switch
    {
        WizardStep.Participants => "Participants",
        WizardStep.Cautionnement => "Cautionnement",
        WizardStep.Pret => "Prêt",
        WizardStep.Autorisation => "Autorisation",
        WizardStep.Charge => "Charges",
        WizardStep.EntiteJuridique => "Entité juridique",
        WizardStep.Recap => "Récap",
        _ => ""
    };

    // =================== UI HELPERS ===================

    private RenderFragment RenderParticipantCard(ParticipantRole role, string title, string iconCss) => @<div class="border rounded p-3 h-100" style="border-color: rgba(0,51,102,.15);">
