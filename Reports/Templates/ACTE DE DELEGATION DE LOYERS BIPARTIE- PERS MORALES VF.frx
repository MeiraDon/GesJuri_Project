          <TableCell Name="Cell39" Border.Lines="Left, Top, Bottom" Text="&#13;&#10;……………………………………&#13;&#10;&#13;&#10;Signification de correspondance                                                          ………………………………&#13;&#10;" Font="Calibri, 12pt"/>
          <TableCell Name="Cell40" Border.Lines="Left, Top" Text="Maître AGBOBLY-ATAYI Ayi Mawuko&#13;&#10;Huissier de Justice&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;LOME&#13;&#10;" Font="Calibri, 12pt, style=Bold"/>
        </TableRow>
      </TableObject>
      <TextObject Name="Text59" Left="37.8" Top="5773.95" Width="642.6" Height="311.85" Text="Cher Maître,&#13;&#10;&#13;&#10;&#13;&#10;Nous vous prions de bien vouloir procéder à :&#13;&#10;&#13;&#10;1-	La signification au locataire dudit acte et de la correspondance à lui adressée et de requérir un état des oppositions et autres empêchements qui pourraient primer la délégation de loyers ou lui nuire.&#13;&#10;2-	L’enregistrement de l’acte de délégation auprès de l’Office Togolais des Recettes.&#13;&#10;&#13;&#10;Votre intervention accomplie, vous voudrez bien nous faire parvenir un exemplaire de votre exploit accompagné des documents requis.&#13;&#10;&#13;&#10;Nous vous remercions de votre collaboration et vous prions d'agréer, Cher Maître, l'expression de nos sentiments distingués&#13;&#10;" HorzAlign="Justify" Font="Calibri, 12pt"/>
      <TableObject Name="Table4" Left="113.4" Top="6123.6" Width="491.52" Height="94.5" Border.Lines="All">
        <TableColumn Name="Column11" Width="245.76"/>
        <TableColumn Name="Column12" Width="245.76"/>
        <TableRow Name="Row10" Height="94.5">
          <TableCell Name="Cell41" Text="&#13;&#10;Signature autorisée&#13;&#10;" HorzAlign="Center" Font="Calibri, 12pt, style=Bold, Italic, Underline"/>
          <TableCell Name="Cell42" Border.Lines="Left" Text="&#13;&#10;Signature autorisée&#13;&#10;&#13;&#10;" HorzAlign="Center" Font="Calibri, 12pt, style=Bold, Italic, Underline"/>
        </TableRow>
      </TableObject>
      <TextObject Name="Text60" Left="37.8" Top="4573.8" Width="642.6" Height="132.3" Text="Au cas où il existerait un empêchement quelconque susceptible de faire obstacle au plein effet de cette domiciliation irrévocable, nous vous prions de bien vouloir nous en aviser.&#13;&#10;&#13;&#10;Nous vous remercions bien vivement de votre coopération et vous prions d’agréer, Monsieur le Directeur, l’expression de nos salutations distinguées." HorzAlign="Justify" Font="Calibri, 12pt"/>
    </DataBand>
