      <TextObject Name="Text37" Left="434.7" Top="3808.35" Width="245.7" Height="66.15" Text="Monsieur (le locataire)&#13;&#10;XXXXXXXXX&#13;&#10;XXXXXXX&#13;&#10;" Font="Calibri, 12pt, style=Bold, Italic"/>
      <TextObject Name="Text38" Left="56.7" Top="3912.3" Width="56.7" Height="37.8" Text="Objet " Font="Calibri, 12pt, style=Bold, Underline"/>
